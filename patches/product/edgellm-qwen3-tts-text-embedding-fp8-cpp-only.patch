+            "text_embedding_scale vocab size should match text_embedding");
+        check::check(textEmbeddingScalesPtr->getShape()[1] == hiddenSize / kFP8EmbeddingBlockSize,
+            "text_embedding_scale group count should match text_embedding hidden size");
+        mTextEmbeddingTable = std::move(*textEmbeddingPtr);
+        mTextEmbeddingScales = std::move(*textEmbeddingScalesPtr);
+        LOG_INFO("FP8 text embedding table loaded: [%lld, %lld], scales: [%lld, %lld]",
+            mTextEmbeddingTable.getShape()[0], mTextEmbeddingTable.getShape()[1], mTextEmbeddingScales.getShape()[0],
+            mTextEmbeddingScales.getShape()[1]);
+    }
+    else
