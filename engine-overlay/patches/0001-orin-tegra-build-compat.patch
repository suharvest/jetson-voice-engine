+function(filter_macos_metadata out_var)
+  set(_items ${${out_var}})
+  list(FILTER _items EXCLUDE REGEX "/\\._[^/]*$")
+  list(FILTER _items EXCLUDE REGEX "/\\.DS_Store$")
+  set(${out_var}
+      "${_items}"
+      PARENT_SCOPE)
+endfunction()
