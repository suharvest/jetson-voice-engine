+void HybridCacheManager::resetLanes(std::vector<int32_t> const& batchIdxs, cudaStream_t stream)
+{
+    // Per-lane reset (spec R1). Zero each named lane's KV length WITHOUT reshaping the shared
+    // tensor: the full mDeviceKVCacheLengths buffer is allocated at maxBatchSize capacity and
+    // never freed (see ctor), so element [batchIdx] is always addressable for any valid lane,
+    // regardless of the current logical activeBatchSize. resetForNewSequences (the one-shot path)
+    // is the ONLY method that reshapes; touching it here would corrupt co-resident lanes.
+    if (batchIdxs.empty())
+    {
+        return;
+    }
+    int32_t* const base = mDeviceKVCacheLengths.dataPointer<int32_t>();
+    for (int32_t const idx : batchIdxs)
+    {
+        check::check(idx >= 0 && idx < mConfig.maxBatchSize,
+            "HybridCacheManager::resetLanes: lane index out of range [0, maxBatchSize).");
+        // Single-element device memset: zero exactly lane `idx`'s INT32 KV length, nothing else.
+        CUDA_CHECK(cudaMemsetAsync(base + idx, 0, sizeof(int32_t), stream));
+    }
+    // Conservative: other (un-reset) lanes may still hold committed KV, so the cache is NOT
+    // globally empty. (resetForNewSequences can set true because it reseeds the whole batch.)
+    mKVCacheAllEmpty = false;
+}
+
+void HybridCacheManager::setLaneLength(int32_t batchIdx, int32_t length, cudaStream_t stream)
+{
+    check::check(batchIdx >= 0 && batchIdx < mConfig.maxBatchSize,
+        "HybridCacheManager::setLaneLength: lane index out of range [0, maxBatchSize).");
+    check::check(length >= 0, "HybridCacheManager::setLaneLength: length must be non-negative.");
+    int32_t* const slot = mDeviceKVCacheLengths.dataPointer<int32_t>() + batchIdx;
+    if (length == 0)
+    {
+        CUDA_CHECK(cudaMemsetAsync(slot, 0, sizeof(int32_t), stream));
+    }
+    else
+    {
+        // Host->device copy of the single length value (no reshape; lane-addressed).
+        CUDA_CHECK(cudaMemcpyAsync(slot, &length, sizeof(int32_t), cudaMemcpyHostToDevice, stream));
+        mKVCacheAllEmpty = false;
+    }
+}
+
+int32_t HybridCacheManager::maxBatchSize() const noexcept
+{
+    return mConfig.maxBatchSize;
+}
