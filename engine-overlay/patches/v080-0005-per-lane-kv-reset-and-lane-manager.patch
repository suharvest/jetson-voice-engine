+// Phase 4 empirical spike — R1 lane-isolation GATE on the v0.8.0 per-lane KV reset.
+//
+// Proves the spec-R1 invariant: HybridCacheManager::resetLanes({0}) zeroes ONLY lane 0's KV
+// length and touches NO other lane's KV-cache bytes or length — i.e. it is a per-element memset,
+// NOT the reshaping full-batch resetForNewSequences that corrupts co-resident lanes.
+//
+// This is OPTION (a) from the Phase-4 plan: drive the resetLanes MECHANISM directly against a
+// manually-constructed 2-lane HybridCacheManager. No engine forward / no ASR session is needed —
+// the isolation property lives entirely in the cache manager's length tensor + KV slabs, so a
+// hand-built 2-lane cache manager is the cleanest, most direct proof (the production ASR engine
+// on this box was built maxBatchSize=1 and cannot host 2 live lanes; a full 2-session run is
+// Phase 5). It also smoke-tests SessionLaneManager acquire/release partitioning.
+//
+// Layout of the combined KV cache for the single attention layer:
+//   [maxBatchSize=2, 2(K/V), numKVHeads=1, maxSeqLen=8, headDim=4]  dtype kHALF
+//   => each lane's contiguous slab = 2*1*8*4 = 64 halves = 128 bytes.
+//
+// Procedure:
+//   1) Build a 2-lane HybridCacheManager (1 attn layer, 0 mamba).
+//   2) Seed lane 0 KV bytes = 0xAA, lane 1 KV bytes = 0xBB (distinct device fills).
+//   3) setLaneLength(0, 5), setLaneLength(1, 7).
+//   4) CAPTURE lane 1: KV-length (peek device length[1]) + a KV-byte sample (D2H of lane 1 slab).
+//   5) resetLanes({0}).
+//   6) RE-CAPTURE lane 1: length + KV bytes.
+//   ASSERT: lane1 length UNCHANGED (7==7); lane1 KV bytes UNCHANGED (all 0xBB, byte-equal);
+//           lane0 length now 0; lane0 KV bytes UNCHANGED (memset hits length only, not KV slab).
+//
+// Exit 0 = PASS, non-zero = FAIL.
+
+#include "common/tensor.h"
+#include "runtime/asrStreamingSessionRuntime.h" // SessionLaneManager
+#include "runtime/hybridCacheManager.h"
+
+#include <NvInfer.h>
+#include <cuda_runtime.h>
+
+#include <cstdint>
+#include <cstdio>
+#include <cstdlib>
+#include <cstring>
+#include <vector>
+
+using namespace trt_edgellm;
+
+#define CK(x)                                                                                                          \
+    do                                                                                                                 \
+    {                                                                                                                  \
+        auto _e = (x);                                                                                                 \
+        if (_e != cudaSuccess)                                                                                         \
+        {                                                                                                              \
+            fprintf(stderr, "CUDA err %s:%d %s\n", __FILE__, __LINE__, cudaGetErrorString(_e));                       \
+            std::exit(3);                                                                                              \
+        }                                                                                                              \
+    } while (0)
+
+namespace
+{
+constexpr int32_t kMaxBatch = 2;
+constexpr int32_t kNumKVHeads = 1;
+constexpr int32_t kHeadDim = 4;
+constexpr int32_t kMaxSeqLen = 8;
+constexpr int32_t kLaneHalves = 2 * kNumKVHeads * kMaxSeqLen * kHeadDim; // 64
+constexpr size_t kLaneBytes = static_cast<size_t>(kLaneHalves) * sizeof(uint16_t); // 128
+
+// Read one lane's committed KV length from the shared device length tensor.
+int32_t peekLen(rt::HybridCacheManager& mgr, int32_t lane, cudaStream_t stream)
+{
+    rt::Tensor& lens = mgr.getKVCacheLengths();
+    int32_t host = -1;
+    CK(cudaMemcpyAsync(&host, lens.dataPointer<int32_t>() + lane, sizeof(int32_t), cudaMemcpyDeviceToHost, stream));
+    CK(cudaStreamSynchronize(stream));
+    return host;
+}
+
+// Download one lane's raw KV-cache slab bytes (layer 0).
+std::vector<uint8_t> sampleKVBytes(rt::HybridCacheManager& mgr, int32_t lane, cudaStream_t stream)
+{
+    rt::Tensor& kv = mgr.getCombinedKVCache(/*absLayerIdx=*/0); // [maxBatch,2,heads,seq,headDim] kHALF
+    auto const* base = static_cast<uint8_t const*>(kv.rawPointer());
+    std::vector<uint8_t> host(kLaneBytes);
+    CK(cudaMemcpyAsync(host.data(), base + static_cast<size_t>(lane) * kLaneBytes, kLaneBytes,
+        cudaMemcpyDeviceToHost, stream));
+    CK(cudaStreamSynchronize(stream));
+    return host;
+}
+
+void fillLaneKV(rt::HybridCacheManager& mgr, int32_t lane, uint8_t pattern, cudaStream_t stream)
+{
+    rt::Tensor& kv = mgr.getCombinedKVCache(0);
+    auto* base = static_cast<uint8_t*>(kv.rawPointer());
+    CK(cudaMemsetAsync(base + static_cast<size_t>(lane) * kLaneBytes, pattern, kLaneBytes, stream));
+    CK(cudaStreamSynchronize(stream));
+}
+
+bool allEqual(std::vector<uint8_t> const& v, uint8_t pat)
+{
+    for (auto b : v)
+    {
+        if (b != pat)
+        {
+            return false;
+        }
+    }
+    return true;
+}
+} // namespace
+
+int main()
+{
+    cudaStream_t stream;
+    CK(cudaStreamCreate(&stream));
+
+    // ── Build a 2-lane HybridCacheManager (1 attention layer, no mamba). ──
+    rt::HybridCacheManager::Config cfg;
+    cfg.maxBatchSize = kMaxBatch;
+    cfg.layerTypes = {rt::HybridCacheManager::LayerType::kAttention};
+
+    cfg.kvConfig.numAttentionLayers = 1;
+    cfg.kvConfig.maxBatchSize = kMaxBatch;
+    cfg.kvConfig.maxSequenceLength = kMaxSeqLen;
+    cfg.kvConfig.kvCacheType = nvinfer1::DataType::kHALF;
+    cfg.kvConfig.layerConfigs = {rt::KVLayerConfig{kNumKVHeads, kHeadDim}};
+
+    cfg.mambaConfig.numRecurrentLayers = 0;
+
+    rt::HybridCacheManager mgr(cfg, stream);
+    CK(cudaStreamSynchronize(stream));
+
+    printf("[m3] maxBatchSize()=%d (want %d)\n", mgr.maxBatchSize(), kMaxBatch);
+    if (mgr.maxBatchSize() != kMaxBatch)
+    {
+        fprintf(stderr, "[m3] FAIL: maxBatchSize mismatch\n");
+        return 1;
+    }
+
+    // Make BOTH lanes active so the length tensor is logically [2] (mirrors a 2-session batch).
+    rt::Tensor reuse({kMaxBatch}, rt::DeviceType::kCPU, nvinfer1::DataType::kINT32, "reuse");
+    reuse.dataPointer<int32_t>()[0] = 0;
+    reuse.dataPointer<int32_t>()[1] = 0;
+    mgr.resetForNewSequences(reuse, stream); // one-shot path: activeBatch=2, both empty
+    CK(cudaStreamSynchronize(stream));
+
+    // Seed distinct KV bytes + lengths per lane.
+    fillLaneKV(mgr, 0, 0xAA, stream);
+    fillLaneKV(mgr, 1, 0xBB, stream);
+    mgr.setLaneLength(0, 5, stream);
+    mgr.setLaneLength(1, 7, stream);
+    CK(cudaStreamSynchronize(stream));
+
+    // ── CAPTURE (before resetLanes). ──
+    int32_t len0_before = peekLen(mgr, 0, stream);
+    int32_t len1_before = peekLen(mgr, 1, stream);
+    std::vector<uint8_t> kv1_before = sampleKVBytes(mgr, 1, stream);
+    std::vector<uint8_t> kv0_before = sampleKVBytes(mgr, 0, stream);
+    printf("[m3] BEFORE resetLanes({0}): len0=%d len1=%d  lane1KV[0..3]=%02x %02x %02x %02x\n",
+        len0_before, len1_before, kv1_before[0], kv1_before[1], kv1_before[2], kv1_before[3]);
+
+    // ── THE GATE: reset ONLY lane 0. ──
+    mgr.resetLanes({0}, stream);
+    CK(cudaStreamSynchronize(stream));
+
+    // ── RE-CAPTURE (after resetLanes). ──
+    int32_t len0_after = peekLen(mgr, 0, stream);
+    int32_t len1_after = peekLen(mgr, 1, stream);
+    std::vector<uint8_t> kv1_after = sampleKVBytes(mgr, 1, stream);
+    std::vector<uint8_t> kv0_after = sampleKVBytes(mgr, 0, stream);
+    printf("[m3] AFTER  resetLanes({0}): len0=%d len1=%d  lane1KV[0..3]=%02x %02x %02x %02x\n",
+        len0_after, len1_after, kv1_after[0], kv1_after[1], kv1_after[2], kv1_after[3]);
+
+    bool ok = true;
+
+    // (1) lane 1 KV LENGTH unchanged.
+    if (len1_after != len1_before || len1_after != 7)
+    {
+        fprintf(stderr, "[m3] FAIL: lane1 length changed (%d -> %d, want 7)\n", len1_before, len1_after);
+        ok = false;
+    }
+    // (2) lane 1 KV BYTES unchanged (byte-equal, still all 0xBB).
+    if (kv1_after != kv1_before || !allEqual(kv1_after, 0xBB))
+    {
+        fprintf(stderr, "[m3] FAIL: lane1 KV bytes changed by resetLanes({0})\n");
+        ok = false;
+    }
+    // (3) lane 0 KV LENGTH now 0.
+    if (len0_after != 0)
+    {
+        fprintf(stderr, "[m3] FAIL: lane0 length not reset (got %d, want 0)\n", len0_after);
+        ok = false;
+    }
+    // (4) lane 0 KV BYTES untouched — resetLanes resets length only, NOT the KV slab.
+    if (kv0_after != kv0_before || !allEqual(kv0_after, 0xAA))
+    {
+        fprintf(stderr, "[m3] FAIL: lane0 KV bytes unexpectedly modified (length-only reset expected)\n");
+        ok = false;
+    }
+    // (5) not-all-empty after a partial reset.
+    if (mgr.getKVCacheAllEmpty())
+    {
+        fprintf(stderr, "[m3] FAIL: getKVCacheAllEmpty()==true after partial resetLanes (lane1 still has KV)\n");
+        ok = false;
+    }
+
+    if (!ok)
+    {
+        fprintf(stderr, "[m3] LANE-ISOLATION GATE FAILED\n");
+        return 1;
+    }
+    printf("[m3] LANE-ISOLATION GATE PASS: lane1 length+bytes UNCHANGED after resetLanes({0}); lane0 length=0; "
+           "lane0 KV bytes intact; allEmpty=false.\n");
+
+    // ── SessionLaneManager partition smoke. ──
+    rt::SessionLaneManager lanes(/*maxBatchSize=*/4, /*asrMax=*/2, /*ttsMax=*/2);
+    int32_t a0 = lanes.acquire(rt::LaneOwnerKind::kAsr, 100);
+    int32_t a1 = lanes.acquire(rt::LaneOwnerKind::kAsr, 101);
+    int32_t a2 = lanes.acquire(rt::LaneOwnerKind::kAsr, 102); // partition full -> -1
+    int32_t t0 = lanes.acquire(rt::LaneOwnerKind::kTts, 200);
+    printf("[m3] SessionLaneManager: asr=%d,%d (3rd=%d) tts=%d (ttsBase=%d)\n", a0, a1, a2, t0, lanes.ttsBase());
+    if (a0 != 0 || a1 != 1 || a2 != -1 || t0 != 2)
+    {
+        fprintf(stderr, "[m3] FAIL: lane partition allocation wrong\n");
+        return 1;
+    }
+    lanes.release(a0);
+    int32_t a0b = lanes.acquire(rt::LaneOwnerKind::kAsr, 103); // reuse freed lane 0
+    if (a0b != 0)
+    {
+        fprintf(stderr, "[m3] FAIL: released ASR lane not reused (got %d)\n", a0b);
+        return 1;
+    }
+    printf("[m3] SessionLaneManager: release/re-acquire ASR lane -> %d OK\n", a0b);
+
+    printf("[m3] ALL PASS\n");
+    return 0;
+}
