+
+#pragma once
+
+#include "runtime/asrStreamingSessionRuntime.h" // SessionLaneManager / LaneOwnerKind
+#include "runtime/qwen3OmniTTSRuntime.h"
+
+#include <cstdint>
+#include <mutex>
+#include <vector>
+
+namespace trt_edgellm
+{
+namespace rt
+{
+
+/*!
+ * @brief N-lane batch scheduler for concurrent CustomVoice / Qwen3-TTS sessions (spec §6 v2, TTS).
+ *
+ * This REPLACES patch-0004's TTS slot-pool RUNTIME REPLICATION (one cloned PipelineIO / scratch /
+ * decode-context per concurrent slot) with the engine's NATIVE batch dimension. A single
+ * `Qwen3OmniTTSRuntime` whose Talker engine is built `--maxBatchSize N` already exposes the
+ * batched entry point `handleAudioGeneration(std::vector<TalkerGenerationRequest>, ...)`, which:
+ *   - runs ONE batched autoregressive Talker decode loop over `activeBatchSize` lanes
+ *     (`runTalkerGenerationLoop(states, activeBatchSize, ...)`, qwen3OmniTTSRuntime.h:388) — this is
+ *     the BATCH lane: row i of the Talker engine's KV cache == TTS lane i, no cross-talk;
+ *   - then, PER BATCH SAMPLE, runs the CodePredictor (batch=1) and (at the example layer) Code2Wav
+ *     (single-sample) SEQUENTIALLY. CodePredictor + Code2Wav are NOT batched — they are looped
+ *     per-lane. That is exactly the spec design (Talker batches; CP/Code2Wav sequential per-lane).
+ *
+ * `TtsBatchLaneManager` is the thin scheduling layer on top: it reserves a persistent TTS lane in
+ * the shared `SessionLaneManager` TTS partition `[asrMax, asrMax + ttsMax)` for each admitted
+ * session (the same static partition the ASR continuous batcher reserves from — so an ASR lane and
+ * a TTS lane can never alias the same HybridCacheManager row), maps that lane to a Talker engine
+ * batch row, admits sessions into free lanes, and on `runBatch()` packs all currently-admitted
+ * lanes into ONE batched `handleAudioGeneration` call. Per-lane RVQ codes come back in
+ * `batchRvqCodes[laneIndex]`; the caller drives Code2Wav per lane (sequential), mirroring the omni
+ * example. No replicated runtime state: the moat (zero cross-talk) is the engine's batch dimension,
+ * proven by the N=2 roundtrip isolation gate, NOT by per-slot cloning.
+ *
+ * Mapping note: the Talker engine has its OWN KV cache rows `[0, N)`. The SessionLaneManager TTS
+ * partition lane id is `ttsBase() + slotIndex`; the Talker engine batch row for that lane is
+ * `slotIndex` (== laneId - ttsBase). `runBatch` packs admitted lanes in ascending slot-index order,
+ * so `batchRvqCodes[k]` belongs to the k-th admitted lane (ascending). Admission order is recorded
+ * so callers can recover which session each batch row served.
+ *
+ * Threading: a single internal mutex serializes admit/runBatch/evict (the runtime's batched call
+ * mutates shared workspace tensors allocated at maxBatchSize).
+ */
+class TtsBatchLaneManager
+{
+public:
+    //! @brief One reserved TTS lane's bookkeeping.
+    struct LaneRecord
+    {
+        int32_t lane{-1};      //!< Physical SessionLaneManager lane id (== HybridCacheManager row in the partition).
+        int32_t batchRow{-1};  //!< Talker engine batch row for this lane (== lane - ttsBase).
+        int64_t sessionId{-1}; //!< Caller session id.
+        bool active{false};    //!< True between admit() and evict().
+        Qwen3OmniTTSRuntime::TalkerGenerationRequest request; //!< The full TTS request for this lane.
+    };
+
+    //! @param runtime  TTS runtime (must outlive this; its Talker engine must be maxBatchSize >= N).
+    //! @param laneManager  Lane allocator (must outlive this); TTS lanes are acquired/released here.
+    TtsBatchLaneManager(Qwen3OmniTTSRuntime& runtime, SessionLaneManager& laneManager) noexcept;
+
+    TtsBatchLaneManager(TtsBatchLaneManager const&) = delete;
+    TtsBatchLaneManager& operator=(TtsBatchLaneManager const&) = delete;
+
+    //! @brief Admit a TTS session into a free TTS lane and record its request.
+    //! @return Physical lane id, or -1 if the TTS partition is full.
+    int32_t admit(int64_t sessionId, Qwen3OmniTTSRuntime::TalkerGenerationRequest const& request);
+
+    //! @brief Run ONE batched Talker decode across all currently-admitted lanes.
+    //! @details Packs admitted lanes (ascending batch-row order) into a single
+    //!          `handleAudioGeneration(std::vector<...>)` on the maxBatchSize=N Talker. On success,
+    //!          `response.batchRvqCodes[k]` / `response.numFramesPerSample[k]` hold the k-th
+    //!          admitted lane's RVQ codes. CodePredictor runs (batch=1) per sample inside the call;
+    //!          the caller runs Code2Wav per lane (sequential). The admitted lane ids in ascending
+    //!          order are written to `outLaneOrder` so the caller can map batch row k -> lane/session.
+    //! @return True if generation succeeded.
+    bool runBatch(Qwen3OmniTTSRuntime::TalkerGenerationResponse& response, std::vector<int32_t>& outLaneOrder,
+        cudaStream_t stream);
+
+    //! @brief Release a lane back to the TTS partition.
+    void evict(int32_t lane);
+
+    //! @brief Number of currently-admitted (active) lanes.
+    int32_t activeLaneCount() const noexcept;
+
+    //! @brief Session id owning a lane (or -1).
+    int64_t sessionOf(int32_t lane) const;
+
+private:
+    Qwen3OmniTTSRuntime& mRuntime;
+    SessionLaneManager& mLaneManager;
+    mutable std::mutex mMutex;
+    std::vector<LaneRecord> mLanes; //!< One record per admitted lane (insertion order).
+};
+
+} // namespace rt
+} // namespace trt_edgellm
