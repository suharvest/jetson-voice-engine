+// spike_v080_m5_tts_concurrent — Phase 5b TTS N=2 batch-lane isolation gate.
+//
+// Drives TWO concurrent CustomVoice sessions with DISTINCT text through TtsBatchLaneManager on a
+// maxBatchSize=2 Talker engine: ONE batched handleAudioGeneration(vector) across both lanes, then
+// per-lane SEQUENTIAL Code2Wav. Compares each lane's CONCURRENT audio to its SOLO run (single-lane
+// admit). PASS == per-lane concurrent RVQ + audio byte-identical to solo, 0 CUDA errors.
+//
+// Usage:
+//   spike_v080_m5_tts_concurrent --talkerEngineDir <b2/talker> --code2wavEngineDir <code2wav>
+//                                --outputAudioDir <dir>
+// Text + speaker + language for the two lanes are fixed below (zh + en, speaker vivian).
+
+#include "audioWriter.h"
+#include "common/checkMacros.h"
+#include "common/logger.h"
+#include "common/trtUtils.h"
+#include "multimodal/code2WavRunner.h"
+#include "runtime/asrStreamingSessionRuntime.h" // SessionLaneManager
+#include "runtime/qwen3OmniTTSRuntime.h"
+#include "runtime/ttsBatchLaneManager.h"
+
+#include <cstdio>
+#include <filesystem>
+#include <getopt.h>
+#include <string>
+#include <vector>
+
+using namespace trt_edgellm;
+using namespace trt_edgellm::rt;
+
+namespace
+{
+
+// One TTS session's fixed input.
+struct SessionSpec
+{
+    std::string tag;      // "zh" / "en"
+    std::string text;     // text to synthesize
+    std::string speaker;  // speaker name
+    std::string language; // CustomVoice language hint
+};
+
+Qwen3OmniTTSRuntime::TalkerGenerationRequest makeRequest(SessionSpec const& spec)
+{
+    Qwen3OmniTTSRuntime::TalkerGenerationRequest req;
+    // Canonical config (Phase A caller requirement): chat template + generation prompt.
+    req.applyChatTemplate = true;
+    req.addGenerationPrompt = true;
+    req.enableThinking = false;
+    // Greedy decode for determinism (byte-identical solo vs concurrent).
+    req.talkerTemperature = 0.0f;
+    req.talkerTopK = 1;
+    req.talkerTopP = 1.0f;
+    req.repetitionPenalty = 1.05f;
+    req.speakerName = spec.speaker;
+    req.language = spec.language;
+    req.maxAudioLength = 4096;
+
+    Message msg;
+    msg.role = "assistant"; // TTS talker prefill expects the assistant role prefix.
+    Message::MessageContent mc;
+    mc.type = "text";
+    mc.content = spec.text;
+    msg.contents.push_back(std::move(mc));
+    req.messages.push_back(std::move(msg));
+    return req;
+}
+
+// Transpose [frames][layers] -> [layers][frames] for Code2Wav.
+std::vector<std::vector<int32_t>> transposeCodes(std::vector<std::vector<int32_t>> const& framesCodes)
+{
+    if (framesCodes.empty())
+    {
+        return {};
+    }
+    size_t const numFrames = framesCodes.size();
+    size_t const numLayers = framesCodes[0].size();
+    std::vector<std::vector<int32_t>> transposed(numLayers, std::vector<int32_t>(numFrames));
+    for (size_t f = 0; f < numFrames; ++f)
+    {
+        for (size_t l = 0; l < numLayers; ++l)
+        {
+            transposed[l][f] = framesCodes[f][l];
+        }
+    }
+    return transposed;
+}
+
+// FNV-1a over the flattened RVQ codes (cheap deterministic fingerprint).
+uint64_t hashCodes(std::vector<std::vector<int32_t>> const& codes)
+{
+    uint64_t h = 1469598103934665603ull;
+    for (auto const& frame : codes)
+    {
+        for (int32_t c : frame)
+        {
+            for (int b = 0; b < 4; ++b)
+            {
+                h ^= static_cast<uint64_t>((c >> (b * 8)) & 0xff);
+                h *= 1099511628211ull;
+            }
+        }
+    }
+    return h;
+}
+
+bool runCode2Wav(Code2WavRunner& runner, std::vector<std::vector<int32_t>> const& framesCodes,
+    audioUtils::AudioData& out, cudaStream_t stream)
+{
+    if (framesCodes.empty())
+    {
+        return false;
+    }
+    auto transposed = transposeCodes(framesCodes);
+    return runner.generateWaveform(transposed, out, stream);
+}
+
+void saveWav(std::string const& dir, std::string const& name, audioUtils::AudioData const& audio)
+{
+    if (dir.empty())
+    {
+        return;
+    }
+    std::filesystem::create_directories(dir);
+    std::filesystem::path p = std::filesystem::path(dir) / (name + ".wav");
+    if (!saveAudioToWav(p.string(), audio))
+    {
+        LOG_WARNING("Failed to save %s", p.string().c_str());
+    }
+    else
+    {
+        LOG_INFO("Saved %s", p.string().c_str());
+    }
+}
+
+} // namespace
+
+int main(int argc, char** argv)
+{
+    std::string talkerEngineDir;
+    std::string code2wavEngineDir;
+    std::string codePredictorEngineDir;
+    std::string tokenizerDir;
+    std::string outputAudioDir;
+    bool debug = false;
+
+    static struct option opts[] = {{"talkerEngineDir", required_argument, 0, 't'},
+        {"code2wavEngineDir", required_argument, 0, 'c'},
+        {"codePredictorEngineDir", required_argument, 0, 'p'},
+        {"tokenizerDir", required_argument, 0, 'k'}, {"outputAudioDir", required_argument, 0, 'o'},
+        {"debug", no_argument, 0, 'd'}, {0, 0, 0, 0}};
+    int o;
+    while ((o = getopt_long(argc, argv, "", opts, nullptr)) != -1)
+    {
+        switch (o)
+        {
+        case 't': talkerEngineDir = optarg; break;
+        case 'c': code2wavEngineDir = optarg; break;
+        case 'p': codePredictorEngineDir = optarg; break;
+        case 'k': tokenizerDir = optarg; break;
+        case 'o': outputAudioDir = optarg; break;
+        case 'd': debug = true; break;
+        default: break;
+        }
+    }
+    if (talkerEngineDir.empty())
+    {
+        fprintf(stderr, "--talkerEngineDir required\n");
+        return EXIT_FAILURE;
+    }
+
+    gLogger.setLevel(debug ? nvinfer1::ILogger::Severity::kVERBOSE : nvinfer1::ILogger::Severity::kINFO);
+    LOG_INFO("=== spike_v080_m5_tts_concurrent (N=2 TTS isolation gate) ===");
+
+    auto pluginHandles = loadEdgellmPluginLib();
+
+    cudaStream_t stream;
+    CUDA_CHECK(cudaStreamCreate(&stream));
+
+    // CodePredictor stays batch=1 (sequential per-lane) — reuse the existing batch=1 CP engine if a
+    // sibling code_predictor/ was not built next to the maxBatchSize=2 Talker.
+    std::string const cpDir = !codePredictorEngineDir.empty()
+        ? codePredictorEngineDir
+        : (std::filesystem::path(talkerEngineDir).parent_path() / "code_predictor").string();
+    // Tokenizer files live in the talker engine dir; default to it (the runtime looks for
+    // tokenizer.json directly in tokenizerDir).
+    std::string const tokDir = !tokenizerDir.empty() ? tokenizerDir : talkerEngineDir;
+    auto ttsRuntime = std::make_unique<Qwen3OmniTTSRuntime>(talkerEngineDir, cpDir, tokDir, stream);
+    LOG_INFO("TTS runtime initialized (Talker %s)", talkerEngineDir.c_str());
+
+    std::filesystem::path const c2wDir = code2wavEngineDir.empty()
+        ? std::filesystem::path(talkerEngineDir).parent_path() / "code2wav"
+        : std::filesystem::path(code2wavEngineDir);
+    auto code2wav = std::make_unique<Code2WavRunner>(c2wDir.string(), stream);
+    LOG_INFO("Code2Wav initialized (%s)", c2wDir.string().c_str());
+
+    // The two distinct concurrent sessions.
+    std::vector<SessionSpec> specs = {
+        {"zh", "今天天气真不错", "vivian", "chinese"},
+        {"en", "the weather is really nice today", "vivian", "english"},
+    };
+
+    // ---------- SOLO baselines (single-lane admit, one at a time) ----------
+    LOG_INFO("--- SOLO baselines (activeBatchSize=1) ---");
+    std::vector<uint64_t> soloHash(specs.size(), 0);
+    std::vector<int32_t> soloFrames(specs.size(), 0);
+    {
+        SessionLaneManager laneMgr(/*maxBatchSize=*/2, /*asrMax=*/0, /*ttsMax=*/2);
+        for (size_t i = 0; i < specs.size(); ++i)
+        {
+            TtsBatchLaneManager batch(*ttsRuntime, laneMgr);
+            int32_t lane = batch.admit(static_cast<int64_t>(100 + i), makeRequest(specs[i]));
+            check::check(lane >= 0, "solo admit failed");
+
+            Qwen3OmniTTSRuntime::TalkerGenerationResponse resp;
+            std::vector<int32_t> order;
+            bool ok = batch.runBatch(resp, order, stream);
+            check::check(ok && !resp.batchRvqCodes.empty(), "solo runBatch failed");
+
+            auto const& codes = resp.batchRvqCodes[0];
+            soloHash[i] = hashCodes(codes);
+            soloFrames[i] = static_cast<int32_t>(codes.size());
+
+            audioUtils::AudioData audio;
+            bool a = runCode2Wav(*code2wav, codes, audio, stream);
+            check::check(a, "solo code2wav failed");
+            saveWav(outputAudioDir, std::string("solo_") + specs[i].tag, audio);
+            int64_t samples = (audio.waveform && !audio.waveform->isEmpty()) ? audio.waveform->getShape()[1] : 0;
+            LOG_INFO("solo %s: frames=%d rvqHash=0x%016llx audioSamples=%ld (%.2fs)", specs[i].tag.c_str(),
+                soloFrames[i], static_cast<unsigned long long>(soloHash[i]), static_cast<long>(samples),
+                static_cast<double>(samples) / (audio.sampleRate ? audio.sampleRate : 24000));
+            batch.evict(lane);
+        }
+    }
+
+    // ---------- CONCURRENT N=2 (both lanes admitted, ONE batched Talker) ----------
+    LOG_INFO("--- CONCURRENT N=2 (activeBatchSize=2, batched Talker) ---");
+    std::vector<uint64_t> ccHash(specs.size(), 0);
+    std::vector<int32_t> ccFrames(specs.size(), 0);
+    {
+        SessionLaneManager laneMgr(/*maxBatchSize=*/2, /*asrMax=*/0, /*ttsMax=*/2);
+        TtsBatchLaneManager batch(*ttsRuntime, laneMgr);
+        std::vector<int32_t> lanes;
+        for (size_t i = 0; i < specs.size(); ++i)
+        {
+            int32_t lane = batch.admit(static_cast<int64_t>(200 + i), makeRequest(specs[i]));
+            check::check(lane >= 0, "concurrent admit failed");
+            lanes.push_back(lane);
+        }
+        LOG_INFO("admitted %d lanes (activeLaneCount=%d)", static_cast<int>(lanes.size()), batch.activeLaneCount());
+
+        Qwen3OmniTTSRuntime::TalkerGenerationResponse resp;
+        std::vector<int32_t> order;
+        bool ok = batch.runBatch(resp, order, stream);
+        check::check(ok, "concurrent runBatch failed");
+        check::check(resp.batchRvqCodes.size() == specs.size(), "concurrent batch size mismatch");
+
+        // order[k] == lane for batch row k; lanes were admitted in spec order, batchRow ascending.
+        for (size_t k = 0; k < specs.size(); ++k)
+        {
+            // batch row k corresponds to spec index k (admit order == ascending batchRow).
+            auto const& codes = resp.batchRvqCodes[k];
+            ccHash[k] = hashCodes(codes);
+            ccFrames[k] = static_cast<int32_t>(codes.size());
+
+            audioUtils::AudioData audio;
+            bool a = runCode2Wav(*code2wav, codes, audio, stream);
+            check::check(a, "concurrent code2wav failed");
+            saveWav(outputAudioDir, std::string("concurrent_") + specs[k].tag, audio);
+            int64_t samples = (audio.waveform && !audio.waveform->isEmpty()) ? audio.waveform->getShape()[1] : 0;
+            LOG_INFO("concurrent %s (lane %d / batch row %zu): frames=%d rvqHash=0x%016llx audioSamples=%ld (%.2fs)",
+                specs[k].tag.c_str(), order[k], k, ccFrames[k], static_cast<unsigned long long>(ccHash[k]),
+                static_cast<long>(samples),
+                static_cast<double>(samples) / (audio.sampleRate ? audio.sampleRate : 24000));
+        }
+        for (int32_t lane : lanes)
+        {
+            batch.evict(lane);
+        }
+    }
+
+    // ---------- VERDICT ----------
+    cudaError_t cudaErr = cudaGetLastError();
+    LOG_INFO("CUDA last-error after concurrent run: %s", cudaGetErrorString(cudaErr));
+
+    LOG_INFO("=== N=2 TTS ISOLATION GATE ===");
+    bool allPass = true;
+    for (size_t i = 0; i < specs.size(); ++i)
+    {
+        bool framesMatch = (ccFrames[i] == soloFrames[i]);
+        bool hashMatch = (ccHash[i] == soloHash[i]);
+        bool pass = framesMatch && hashMatch;
+        allPass = allPass && pass;
+        LOG_INFO("lane %s: concurrent frames=%d/solo=%d  rvqHash cc=0x%016llx solo=0x%016llx  => %s",
+            specs[i].tag.c_str(), ccFrames[i], soloFrames[i], static_cast<unsigned long long>(ccHash[i]),
+            static_cast<unsigned long long>(soloHash[i]), pass ? "PASS" : "FAIL");
+    }
+    bool cudaClean = (cudaErr == cudaSuccess);
+    LOG_INFO("0 CUDA errors across concurrent run: %s", cudaClean ? "YES" : "NO");
+    allPass = allPass && cudaClean;
+    LOG_INFO("=== M5 (N=2 TTS ISOLATION) ACCEPTANCE: %s ===", allPass ? "PASS" : "FAIL");
+
+    cudaStreamDestroy(stream);
+    return allPass ? EXIT_SUCCESS : EXIT_FAILURE;
+}
