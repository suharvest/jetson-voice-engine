+
+#include "runtime/ttsBatchLaneManager.h"
+
+#include "common/logger.h"
+
+#include <algorithm>
+
+namespace trt_edgellm
+{
+namespace rt
+{
+
+TtsBatchLaneManager::TtsBatchLaneManager(Qwen3OmniTTSRuntime& runtime, SessionLaneManager& laneManager) noexcept
+    : mRuntime(runtime)
+    , mLaneManager(laneManager)
+{
+}
+
+int32_t TtsBatchLaneManager::admit(int64_t sessionId, Qwen3OmniTTSRuntime::TalkerGenerationRequest const& request)
+{
+    std::lock_guard<std::mutex> lock(mMutex);
+
+    int32_t const lane = mLaneManager.acquire(LaneOwnerKind::kTts, sessionId);
+    if (lane < 0)
+    {
+        LOG_WARNING("TtsBatchLaneManager: TTS partition full, cannot admit session %ld", static_cast<long>(sessionId));
+        return -1;
+    }
+
+    LaneRecord rec;
+    rec.lane = lane;
+    rec.batchRow = lane - mLaneManager.ttsBase();
+    rec.sessionId = sessionId;
+    rec.active = true;
+    rec.request = request;
+    mLanes.push_back(std::move(rec));
+
+    LOG_INFO("TtsBatchLaneManager: admitted session %ld -> lane %d (Talker batch row %d)",
+        static_cast<long>(sessionId), lane, lane - mLaneManager.ttsBase());
+    return lane;
+}
+
+bool TtsBatchLaneManager::runBatch(Qwen3OmniTTSRuntime::TalkerGenerationResponse& response,
+    std::vector<int32_t>& outLaneOrder, cudaStream_t stream)
+{
+    std::lock_guard<std::mutex> lock(mMutex);
+
+    // Collect active lanes in ASCENDING Talker-batch-row order. Row k of the engine's KV cache is
+    // TTS lane k; packing in row order keeps response.batchRvqCodes[k] aligned to lane order.
+    std::vector<LaneRecord*> ordered;
+    for (auto& rec : mLanes)
+    {
+        if (rec.active)
+        {
+            ordered.push_back(&rec);
+        }
+    }
+    std::sort(ordered.begin(), ordered.end(),
+        [](LaneRecord const* a, LaneRecord const* b) { return a->batchRow < b->batchRow; });
+
+    if (ordered.empty())
+    {
+        LOG_WARNING("TtsBatchLaneManager::runBatch: no active lanes");
+        return false;
+    }
+
+    // Pack one TalkerGenerationRequest per active lane -> ONE batched handleAudioGeneration call.
+    // This is the BATCH lane: the maxBatchSize=N Talker runs all lanes' autoregressive decode in a
+    // single batched engine loop; CodePredictor (batch=1) is run per-sample SEQUENTIALLY inside.
+    std::vector<Qwen3OmniTTSRuntime::TalkerGenerationRequest> batch;
+    batch.reserve(ordered.size());
+    outLaneOrder.clear();
+    outLaneOrder.reserve(ordered.size());
+    for (auto* rec : ordered)
+    {
+        batch.push_back(rec->request);
+        outLaneOrder.push_back(rec->lane);
+    }
+
+    LOG_INFO("TtsBatchLaneManager::runBatch: batched Talker over %zu lane(s) (activeBatchSize=%zu)", batch.size(),
+        batch.size());
+
+    bool const ok = mRuntime.handleAudioGeneration(batch, response, stream);
+    if (!ok)
+    {
+        LOG_ERROR("TtsBatchLaneManager::runBatch: handleAudioGeneration failed");
+    }
+    return ok;
+}
+
+void TtsBatchLaneManager::evict(int32_t lane)
+{
+    std::lock_guard<std::mutex> lock(mMutex);
+    auto it = std::find_if(mLanes.begin(), mLanes.end(), [lane](LaneRecord const& r) { return r.lane == lane; });
+    if (it == mLanes.end() || !it->active)
+    {
+        return;
+    }
+    it->active = false;
+    mLaneManager.release(lane);
+    LOG_INFO("TtsBatchLaneManager: evicted lane %d (session %ld)", lane, static_cast<long>(it->sessionId));
+    mLanes.erase(it);
+}
+
+int32_t TtsBatchLaneManager::activeLaneCount() const noexcept
+{
+    std::lock_guard<std::mutex> lock(mMutex);
+    return static_cast<int32_t>(std::count_if(mLanes.begin(), mLanes.end(), [](LaneRecord const& r) { return r.active; }));
+}
+
+int64_t TtsBatchLaneManager::sessionOf(int32_t lane) const
+{
+    std::lock_guard<std::mutex> lock(mMutex);
+    auto it = std::find_if(mLanes.begin(), mLanes.end(), [lane](LaneRecord const& r) { return r.lane == lane; });
+    return it == mLanes.end() ? -1 : it->sessionId;
+}
+
+} // namespace rt
+} // namespace trt_edgellm
