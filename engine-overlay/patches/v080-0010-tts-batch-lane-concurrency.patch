+# ---------------------------------------------------------------------------
+# Phase 5b: TTS N=2 batch-lane concurrency isolation gate (spec section 6 v2 TTS).
+# Drives two concurrent CustomVoice sessions through TtsBatchLaneManager on a
+# maxBatchSize=2 Talker engine (native batch), with sequential per-lane Code2Wav.
+# Same CuTe DSL shim + --wrap link requirements as qwen3_tts_inference.
+# ---------------------------------------------------------------------------
+add_executable(spike_v080_m5_tts_concurrent spike_v080_m5_tts_concurrent.cpp)
+
+target_include_directories(
+  spike_v080_m5_tts_concurrent PRIVATE ${COMMON_INCLUDE_DIRS}
+                                       ${CMAKE_SOURCE_DIR}/examples/utils)
+
+target_link_libraries(spike_v080_m5_tts_concurrent PRIVATE edgellmCore exampleUtils
+                                                           commonLibraryExt)
+
+add_cross_build_link_options(spike_v080_m5_tts_concurrent)
+if(TARGET trt_edgellm_cutedsl_cudart_shim)
+  target_link_libraries(spike_v080_m5_tts_concurrent PRIVATE
+    "-Wl,--whole-archive" trt_edgellm_cutedsl_cudart_shim "-Wl,--no-whole-archive")
+  if(NOT DEFINED CUDA_CTK_VERSION OR CUDA_CTK_VERSION STREQUAL ""
+     OR CUDA_CTK_VERSION VERSION_LESS 12.8)
+    target_link_options(spike_v080_m5_tts_concurrent PRIVATE
+      "-Wl,--wrap=_cudaLaunchKernelEx")
+  endif()
+endif()
+
+set_target_properties(
+  spike_v080_m5_tts_concurrent PROPERTIES RUNTIME_OUTPUT_DIRECTORY
+                                          ${CMAKE_BINARY_DIR}/examples/omni)
