+void LLMInferenceRuntime::restoreKvCacheLength(int32_t lane, int32_t savedLen, cudaStream_t stream)
+{
+    // Mirror of the D2H read in peekKvCacheLength: write the saved int32 BACK into the shared
+    // device KV-length tensor at [lane] (1-element H2D). KV memory itself is untouched — the
+    // speculative tail past savedLen is dead and is overwritten by the next append.
+    auto& cacheMgr = *mSharedResources->cacheManagers[0];
+    rt::Tensor& kvLengths = cacheMgr.getKVCacheLengths(); // device INT32 [*]
+    if (lane < 0 || lane >= cacheMgr.maxBatchSize())
+    {
+        LOG_ERROR("restoreKvCacheLength: lane=%d out of range [0, %d)", lane, cacheMgr.maxBatchSize());
+        return;
+    }
+    CUDA_CHECK(cudaMemcpyAsync(kvLengths.dataPointer<int32_t>() + lane, &savedLen, sizeof(int32_t),
+        cudaMemcpyHostToDevice, stream));
+    CUDA_CHECK(cudaStreamSynchronize(stream));
+}
