+DecodePeekResult LLMInferenceRuntime::peekAsrSessionTranscript(
+    DecodingInferenceContext& context, int32_t lane, int32_t maxNewTokens, cudaStream_t stream)
+{
+    // Serialize the whole peek against any other engine step (shared PipelineIO).
+    std::lock_guard<std::mutex> execLock(mEngineExecMutex);
+
+    DecodePeekResult result;
+
+    auto& cacheMgr = *mSharedResources->cacheManagers[0];
+    if (lane < 0 || lane >= context.activeBatchSize)
+    {
+        LOG_ERROR("peekAsrSessionTranscript: lane=%d out of range [0, %d)", lane, context.activeBatchSize);
+        return result;
+    }
+
+    // ── SNAPSHOT (BEFORE any mutation) ───────────────────────────────────────
+    // The decode+evict path mutates the ENTIRE context (tokenIds/currentGenerateLengths/
+    // finishedStates/effectivePrefillLengths/slotStreams/batchIndexMapping/completedBatches/
+    // generationRound/activeBatchSize and more — see performBatchEvict), so we copy the whole
+    // struct. DecodingInferenceContext is value-copyable (all std::vector / unordered_map / POD;
+    // OptionalInputTensor is a copyable reference_wrapper; SlotStreamState holds the channel by
+    // shared_ptr). We also snapshot the device KV-length for `lane` and the cache-manager active
+    // batch size, which performBatchEvict drives to 0.
+    DecodingInferenceContext const snapshot = context; // full deep copy of the value-typed fields
+    int32_t const savedKvLen = peekKvCacheLength(lane, stream);
+    int32_t const savedCacheActiveBatch = cacheMgr.getActiveBatchSize();
+    if (savedKvLen < 0)
+    {
+        LOG_ERROR("peekAsrSessionTranscript: failed to read saved KV length for lane=%d", lane);
+        return result;
+    }
+
+    // Bound the speculative decode to maxNewTokens past whatever is already generated, by
+    // temporarily clamping maxGenerateLength (updateFinishStates terminates a lane once
+    // currentGenerateLengths[lane] >= maxGenerateLength).
+    int32_t const baseGen = context.currentGenerateLengths.empty() ? 0 : context.currentGenerateLengths[lane];
+    int32_t const cap = baseGen + (maxNewTokens > 0 ? maxNewTokens : 1);
+    if (context.maxGenerateLength > cap)
+    {
+        context.maxGenerateLength = cap;
+    }
+
+    // ── SPECULATIVE DECODE TO EOS (MUTATES + EVICTS the lane) ─────────────────
+    // Reuse the exact greedy step decodeAsrSessionToCompletion uses (vanilla / cache-priming
+    // strategy; ASR thinker engines are non-speculative). This drives the same per-step kernels
+    // as the committing path, but every field it touches is restored below.
+    DecodingStrategy& strategy = mDecoderRegistry->cachePrimingStrategy();
+    bool const decodeOk = decodeToCompletion(context, strategy);
+
+    if (decodeOk)
+    {
+        result.transcript = getAsrSessionTranscript(context);
+        if (!context.completedBatches.empty())
+        {
+            result.generatedTokens = context.completedBatches.begin()->second.generateLength;
+        }
+        result.ok = true;
+    }
+    else
+    {
+        LOG_ERROR("peekAsrSessionTranscript: speculative decodeToCompletion failed; restoring state anyway");
+    }
+
+    // ── HARD-RESTORE (TOTAL) ─────────────────────────────────────────────────
+    // 1) CPU context: overwrite with the pre-peek snapshot (resurrects tokenIds[lane],
+    //    currentGenerateLengths, finishedStates, effectivePrefillLengths, slotStreams,
+    //    batchIndexMapping, completedBatches, generationRound, activeBatchSize, maxGenerateLength).
+    context = snapshot;
+    // 2) Cache-manager active batch size (evict drove it to 0).
+    cacheMgr.setActiveBatchSize(savedCacheActiveBatch);
+    // 3) Device KV-length tensor for `lane` (evict compacted it away). The KV CONTENT at row
+    //    `lane` was never overwritten — compactBatch only relocates RETAINED lanes; an evicted
+    //    single lane's source row is left physically resident — so restoring the length fully
+    //    resurrects the committed cache.
+    restoreKvCacheLength(lane, savedKvLen, stream);
+
+    return result;
+}
