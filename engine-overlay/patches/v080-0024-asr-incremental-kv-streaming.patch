+DecodePeekResult AsrStreamingSessionRuntime::peekTranscriptWithSuffix(
+    std::vector<int32_t> const& suffixTokenIds, int32_t maxNewTokens, cudaStream_t stream)
+{
+    DecodePeekResult result;
+    if (mStatus != AsrSessionStatus::kActive)
+    {
+        LOG_ERROR("peekTranscriptWithSuffix: session not active (status=%d)", static_cast<int32_t>(mStatus));
+        return result;
+    }
+    if (suffixTokenIds.empty())
+    {
+        LOG_ERROR("peekTranscriptWithSuffix: empty suffix");
+        return result;
+    }
+
+    // ── SNAPSHOT the FULL durable session state BEFORE the speculative suffix-append ──
+    // appendChunkImpl(suffix, isFinal=true) mutates: mContext (tokenIds + device KV length via
+    // appendPrefillChunk + sampled token), mStatus->kFinished, mAppendedTokens, mChunkCount,
+    // mPendingTextTail. The inner peek then snapshots/decodes/restores ITS OWN decode (back to the
+    // post-suffix-append state). We restore the rest back to the pre-suffix-append state here, so
+    // the durable state after this whole call equals the state before it.
+    DecodingInferenceContext const ctxSnapshot = mContext;
+    AsrSessionStatus const statusSnapshot = mStatus;
+    int32_t const appendedSnapshot = mAppendedTokens;
+    int32_t const chunkCountSnapshot = mChunkCount;
+    std::vector<int32_t> const pendingTailSnapshot = mPendingTextTail;
+    int32_t const savedKvLen = mRuntime.peekKvCacheLength(mLane, stream);
+    if (savedKvLen < 0)
+    {
+        LOG_ERROR("peekTranscriptWithSuffix: failed to read saved KV length for lane=%d", mLane);
+        return result;
+    }
+
+    // ── SPECULATIVE SUFFIX-APPEND (audio_end + assistant suffix as a FINAL text chunk) ──
+    // Samples a token, transitions to kFinished — exactly the state the Phase-1 peek decodes from.
+    if (!appendChunkImpl(suffixTokenIds, /*mel=*/nullptr, /*isFinalChunk=*/true, stream))
+    {
+        LOG_ERROR("peekTranscriptWithSuffix: speculative suffix append failed; restoring");
+        // appendChunkImpl only mutates member state AFTER appendPrefillChunk succeeds, so a failed
+        // append leaves mContext/cursors intact. But the device KV length may have advanced if the
+        // prefill committed before a later step failed; restore it defensively.
+        mContext = ctxSnapshot;
+        mStatus = statusSnapshot;
+        mAppendedTokens = appendedSnapshot;
+        mChunkCount = chunkCountSnapshot;
+        mPendingTextTail = pendingTailSnapshot;
+        mRuntime.restoreKvCacheLength(mLane, savedKvLen, stream);
+        return result;
+    }
+
+    // ── NON-EVICTING PEEK DECODE (Phase-1 primitive; snapshots/restores its own decode) ──
+    result = mRuntime.peekAsrSessionTranscript(mContext, mLane, maxNewTokens, stream);
+
+    // ── HARD-RESTORE to the PRE-suffix-append durable state ──
+    // Undo the speculative suffix-append: CPU context + cursors + status + the device KV length the
+    // suffix prefill grew (the KV content past savedKvLen is dead and overwritten by the next real
+    // delta append — same mechanism as the Phase-1 peek restore).
+    mContext = ctxSnapshot;
+    mStatus = statusSnapshot;
+    mAppendedTokens = appendedSnapshot;
+    mChunkCount = chunkCountSnapshot;
+    mPendingTextTail = pendingTailSnapshot;
+    mRuntime.restoreKvCacheLength(mLane, savedKvLen, stream);
+
+    return result;
+}
