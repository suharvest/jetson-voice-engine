+bool Qwen3OmniAudioRunner::initializeSequentialMRopeLane(
+    int32_t lane, int32_t maxPositions, rt::Tensor& mropeCosSin, cudaStream_t stream)
+{
+    if (mConfig.mropeTheta <= 0.0F)
+    {
+        // Not an MRope model, nothing to do.
+        return true;
+    }
+
+    // The shared PipelineIO::mropeCosSin keeps its full [maxBatch, maxPositionEmbeddings,
+    // rotaryDim] shape — we MUST NOT reshape it here (other lanes share the buffer). Read
+    // the per-lane geometry directly from the live shape.
+    auto const ropeShape = mropeCosSin.getShape();
+    if (ropeShape.getNumDims() != 3)
+    {
+        LOG_ERROR("initializeSequentialMRopeLane: mropeCosSin has unexpected rank %d (want 3)",
+            ropeShape.getNumDims());
+        return false;
+    }
+    int64_t const maxBatch = ropeShape[0];
+    int64_t const maxPositionEmbeddings = ropeShape[1];
+    int64_t const rotaryDim = ropeShape[2];
+
+    if (lane < 0 || static_cast<int64_t>(lane) >= maxBatch)
+    {
+        LOG_ERROR("initializeSequentialMRopeLane: lane=%d out of range [0, %ld)", lane, maxBatch);
+        return false;
+    }
+
+    if (maxPositions > maxPositionEmbeddings)
+    {
+        LOG_ERROR(
+            "initializeSequentialMRopeLane: maxPositions=%d exceeds MRope cache capacity "
+            "(maxPositionEmbeddings=%ld); rebuild thinker engine with larger capacity.",
+            maxPositions, maxPositionEmbeddings);
+        return false;
+    }
+
+    // Build host position IDs for a SINGLE lane: [1, 3, maxPositionEmbeddings].
+    // For audio+text only, all 3 dimensions (T, H, W) use identical sequential
+    // positions [0, 1, 2, ...] — same layout as the one-shot path.
+    int64_t const numElements = 3 * maxPositionEmbeddings;
+    std::vector<int64_t> positionIdsHost(numElements);
+    for (int64_t dim = 0; dim < 3; ++dim)
+    {
+        for (int64_t pos = 0; pos < maxPositionEmbeddings; ++pos)
+        {
+            positionIdsHost[dim * maxPositionEmbeddings + pos] = pos;
+        }
+    }
+
+    rt::Tensor positionIdsDevice({1, 3, maxPositionEmbeddings}, rt::DeviceType::kGPU, nvinfer1::DataType::kINT64,
+        "sequentialMRopeLanePositionIds");
+    CUDA_CHECK(cudaMemcpyAsync(positionIdsDevice.rawPointer(), positionIdsHost.data(), numElements * sizeof(int64_t),
+        cudaMemcpyHostToDevice, stream));
+
+    // Target only this lane's contiguous slab of the shared cache: each batch row is
+    // maxPositionEmbeddings * rotaryDim floats, laid out contiguously (verified against the
+    // one-shot path's [activeBatchSize, maxPositionEmbeddings, rotaryDim] layout). Launch
+    // the kernel with batchSize=1 over the offset pointer — NO reshape of the shared buffer.
+    float* const laneCosSin = mropeCosSin.dataPointer<float>() + static_cast<int64_t>(lane) * maxPositionEmbeddings * rotaryDim;
+
+    // All audio+text MRope models (Qwen3-ASR, Qwen3-Omni) use interleaved layout.
+    bool constexpr interleaved = true;
+    try
+    {
+        kernel::initializeMRopeCosSin(laneCosSin, positionIdsDevice.dataPointer<int64_t>(), mConfig.mropeTheta,
+            rotaryDim, maxPositionEmbeddings, /*batchSize=*/1, interleaved, mConfig.mropeSectionH, mConfig.mropeSectionW,
+            stream);
+    }
+    catch (std::exception const& e)
+    {
+        LOG_ERROR("initializeSequentialMRopeLane: kernel launch failed: %s", e.what());
+        return false;
+    }
+
+    // Synchronize to ensure kernel completes before local positionIdsDevice is freed.
+    CUDA_CHECK(cudaStreamSynchronize(stream));
+    LOG_INFO("Initialized sequential MRope cos/sin cache for lane %d, %ld positions (maxPositions=%d)", lane,
+        maxPositionEmbeddings, maxPositions);
+
+    return true;
+}
