+    //
+    // The single-token append-prefill guard (v080-0004) coalesces a non-final TEXT chunk's
+    // trailing token forward into the next chunk so that no prefill step of length 1 ever
+    // lands on a non-empty KV cache (which the AttentionPlugin would misroute to the decode
+    // path). After a non-final text chunk of length L>=2 the runtime therefore commits L-1
+    // tokens and carries 1 forward; the carried token is committed by the next chunk. The
+    // FINAL cumulative KV is unchanged (kvB2 == totalTokens) and KV is still strictly
+    // monotonic — only the intermediate boundary is pulled back by exactly the one carried
+    // token. We accept kvB1 in {splitAt-1, splitAt} accordingly.
+    bool const kvB1Ok = (kvB1 == splitAt) || (kvB1 == splitAt - 1);
+    bool kvR3 = kvB1Ok && (kvB2 == totalTokens) && (kvA == totalTokens);
+    printf("R3 KV continuity: A_kv=%d  B_kv1=%d(exp %d or %d, carry-over)  B_kv2=%d(exp %d)  => %s\n", kvA, kvB1,
+        splitAt - 1, splitAt, kvB2, totalTokens, kvR3 ? "PASS" : "FAIL");
     ok = ok && kvR3;
 
     if (logitsA.empty() || logitsB.empty() || logitsA.size() != logitsB.size())
