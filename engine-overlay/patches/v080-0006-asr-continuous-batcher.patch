diff --git a/examples/llm/spike_v080_m4_concurrent_lanes.cpp b/examples/llm/spike_v080_m4_concurrent_lanes.cpp
new file mode 100644
index 0000000..de06af3
--- /dev/null
+++ b/examples/llm/spike_v080_m4_concurrent_lanes.cpp
@@ -0,0 +1,256 @@
+// Phase 5a empirical spike — THE N=2 ASR ISOLATION GATE (the moat property).
+//
+// Proves that running two concurrent streaming-ASR sessions through the new
+// rt::AsrContinuousBatcher over a maxBatchSize=2 v0.8.0 qwen3-asr thinker engine introduces
+// ZERO cross-talk: each lane's per-step sampled logits / argmax are BYTE-IDENTICAL to that same
+// session run SOLO (single-lane). Accuracy > speed — the value is provable per-lane isolation.
+//
+// Procedure:
+//   SOLO baselines (one lane, activeBatchSize=1 via the batcher with a single admit):
+//     Session A — distinct token stream SA, chunked SA0 + SA1 → final logits LA_solo.
+//     Session B — distinct token stream SB (different seed), chunked SB0 + SB1 → LB_solo.
+//   CONCURRENT (two lanes, activeBatchSize=2, lockstep ticks):
+//     admit A→lane0, admit B→lane1; enqueue both lanes' chunk0 (non-final), tick();
+//     enqueue both lanes' chunk1 (final), tick(); read lane0/lane1 logits → LA_cc, LB_cc.
+//   GATE:
+//     argmax(LA_cc)==argmax(LA_solo)  &&  max_i|LA_cc[i]-LA_solo[i]| < 1e-2  (PASS = diff 0.0)
+//     argmax(LB_cc)==argmax(LB_solo)  &&  max_i|LB_cc[i]-LB_solo[i]| < 1e-2
+//   + 0 CUDA errors across the concurrent run (checked after every batcher call + a final
+//     cudaGetLastError + stream sync).
+//
+// Distinct token streams (different seeds) guarantee the two lanes carry genuinely different KV /
+// logits, so a batched step that leaked across rows WOULD perturb the diff. Text tokens only (no
+// mel) isolate the batched prefill-chunk packing/exec/commit/sample math — the batcher's seam.
+//
+// Exit 0 = PASS.
+
+#include "common/tensor.h"
+#include "common/trtUtils.h" // loadEdgellmPluginLib — registers AttentionPlugin before deserialize
+#include "runtime/asrContinuousBatcher.h"
+#include "runtime/asrStreamingSessionRuntime.h" // SessionLaneManager
+#include "runtime/llmInferenceRuntime.h"
+
+#include <cuda_runtime.h>
+
+#include <algorithm>
+#include <cmath>
+#include <cstdint>
+#include <cstdio>
+#include <cstdlib>
+#include <random>
+#include <string>
+#include <unordered_map>
+#include <vector>
+
+using namespace trt_edgellm;
+
+#define CK(x)                                                                                                          \
+    do                                                                                                                 \
+    {                                                                                                                  \
+        auto _e = (x);                                                                                                 \
+        if (_e != cudaSuccess)                                                                                         \
+        {                                                                                                              \
+            fprintf(stderr, "CUDA err %s:%d %s\n", __FILE__, __LINE__, cudaGetErrorString(_e));                       \
+            std::exit(2);                                                                                              \
+        }                                                                                                              \
+    } while (0)
+
+namespace
+{
+constexpr int32_t kMaxPositions = 1024;
+
+int argmax(std::vector<float> const& v)
+{
+    int k = 0;
+    for (int i = 1; i < static_cast<int>(v.size()); ++i)
+        if (v[i] > v[k])
+            k = i;
+    return k;
+}
+
+std::vector<int32_t> makeTextTokens(int n, uint32_t seed)
+{
+    std::vector<int32_t> ids(n);
+    std::mt19937 gen(seed);
+    std::uniform_int_distribution<int32_t> dis(1, 100000);
+    for (auto& t : ids)
+        t = dis(gen);
+    return ids;
+}
+
+// Run ONE session solo through a fresh single-lane batcher: admit → chunk0(!final) → chunk1(final).
+// Returns the lane-0 final logits.
+std::vector<float> runSolo(rt::LLMInferenceRuntime& runtime, std::vector<int32_t> const& chunk0,
+    std::vector<int32_t> const& chunk1, cudaStream_t stream)
+{
+    rt::SessionLaneManager laneMgr(/*maxBatchSize=*/2, /*asrMax=*/2, /*ttsMax=*/0);
+    rt::AsrContinuousBatcher batcher(runtime, laneMgr);
+    int32_t lane = batcher.admit(/*sessionId=*/0, /*prompt=*/{}, kMaxPositions, stream);
+    if (lane != 0)
+    {
+        fprintf(stderr, "SOLO: expected lane 0, got %d\n", lane);
+        std::exit(1);
+    }
+    batcher.enqueueChunk(lane, chunk0, /*isFinal=*/false);
+    if (batcher.tick(stream) < 0)
+    {
+        fprintf(stderr, "SOLO: tick(chunk0) failed\n");
+        std::exit(1);
+    }
+    batcher.enqueueChunk(lane, chunk1, /*isFinal=*/true);
+    if (batcher.tick(stream) < 0)
+    {
+        fprintf(stderr, "SOLO: tick(chunk1) failed\n");
+        std::exit(1);
+    }
+    CK(cudaStreamSynchronize(stream));
+    auto logits = batcher.getLogitsForTesting(lane, stream);
+    batcher.evict(lane, stream);
+    CK(cudaStreamSynchronize(stream));
+    return logits;
+}
+} // namespace
+
+int main(int argc, char** argv)
+{
+    std::string engineDir = "/home/harvest/tensorrt-edgellm-workspace/Qwen3-ASR-0.6B/engines-v080-b2/llm";
+    std::string multimodalEngineDir = ""; // text-only token prefill — no audio encoder.
+    int totalTokens = 64;
+    int splitAt = 32;
+    if (argc >= 2)
+        engineDir = argv[1];
+    if (argc >= 4)
+    {
+        totalTokens = std::atoi(argv[2]);
+        splitAt = std::atoi(argv[3]);
+    }
+    if (splitAt <= 0 || splitAt >= totalTokens)
+    {
+        fprintf(stderr, "FATAL: splitAt(%d) must be in (0, totalTokens=%d)\n", splitAt, totalTokens);
+        return 2;
+    }
+
+    auto pluginHandles = loadEdgellmPluginLib();
+
+    cudaStream_t stream;
+    CK(cudaStreamCreate(&stream));
+
+    std::unordered_map<std::string, std::string> loraMap;
+    std::unique_ptr<rt::LLMInferenceRuntime> runtime;
+    try
+    {
+        runtime = std::make_unique<rt::LLMInferenceRuntime>(engineDir, multimodalEngineDir, loraMap, stream);
+    }
+    catch (std::exception const& e)
+    {
+        fprintf(stderr, "FATAL: runtime construction failed: %s\n", e.what());
+        return 2;
+    }
+    printf("runtime constructed against %s\n", engineDir.c_str());
+    printf("maxSessionBatchSize=%d\n", runtime->maxSessionBatchSize());
+    if (runtime->maxSessionBatchSize() < 2)
+    {
+        fprintf(stderr, "FATAL: engine maxBatchSize=%d < 2 — this gate needs a maxBatchSize>=2 engine.\n",
+            runtime->maxSessionBatchSize());
+        return 2;
+    }
+
+    // Two DISTINCT token streams (different seeds) — same shape, different content.
+    auto const tokensA = makeTextTokens(totalTokens, /*seed*/ 1234);
+    auto const tokensB = makeTextTokens(totalTokens, /*seed*/ 9876);
+    std::vector<int32_t> a0(tokensA.begin(), tokensA.begin() + splitAt), a1(tokensA.begin() + splitAt, tokensA.end());
+    std::vector<int32_t> b0(tokensB.begin(), tokensB.begin() + splitAt), b1(tokensB.begin() + splitAt, tokensB.end());
+
+    // ── SOLO baselines ───────────────────────────────────────────────────────
+    printf("\n--- SOLO baselines (activeBatchSize=1) ---\n");
+    auto LA_solo = runSolo(*runtime, a0, a1, stream);
+    auto LB_solo = runSolo(*runtime, b0, b1, stream);
+    printf("solo A: argmax=%d  |logits|=%zu\n", argmax(LA_solo), LA_solo.size());
+    printf("solo B: argmax=%d  |logits|=%zu\n", argmax(LB_solo), LB_solo.size());
+
+    // ── CONCURRENT (two lanes, lockstep, activeBatchSize=2) ──────────────────
+    printf("\n--- CONCURRENT N=2 (activeBatchSize=2, lockstep) ---\n");
+    rt::SessionLaneManager laneMgr(/*maxBatchSize=*/2, /*asrMax=*/2, /*ttsMax=*/0);
+    rt::AsrContinuousBatcher batcher(*runtime, laneMgr);
+
+    int32_t laneA = batcher.admit(/*sessionId=*/101, {}, kMaxPositions, stream);
+    int32_t laneB = batcher.admit(/*sessionId=*/202, {}, kMaxPositions, stream);
+    CK(cudaGetLastError());
+    printf("admit: laneA=%d laneB=%d activeBatch=%d\n", laneA, laneB, batcher.activeBatchSize());
+    if (laneA != 0 || laneB != 1 || batcher.activeBatchSize() != 2)
+    {
+        fprintf(stderr, "FATAL: expected laneA=0 laneB=1 activeBatch=2; got %d %d %d\n", laneA, laneB,
+            batcher.activeBatchSize());
+        return 1;
+    }
+
+    // Tick 1: both lanes' chunk0 (non-final) → one batched activeBatchSize=2 prefill.
+    batcher.enqueueChunk(laneA, a0, /*isFinal=*/false);
+    batcher.enqueueChunk(laneB, b0, /*isFinal=*/false);
+    int32_t adv1 = batcher.tick(stream);
+    CK(cudaGetLastError());
+    printf("tick1 advanced=%d  kvA=%d kvB=%d\n", adv1, batcher.peekKvCacheLength(laneA, stream),
+        batcher.peekKvCacheLength(laneB, stream));
+    if (adv1 != 2)
+    {
+        fprintf(stderr, "FATAL: tick1 expected to advance 2 lanes, got %d\n", adv1);
+        return 1;
+    }
+
+    // Tick 2: both lanes' chunk1 (final) → batched activeBatchSize=2 prefill + sample.
+    batcher.enqueueChunk(laneA, a1, /*isFinal=*/true);
+    batcher.enqueueChunk(laneB, b1, /*isFinal=*/true);
+    int32_t adv2 = batcher.tick(stream);
+    CK(cudaGetLastError());
+    CK(cudaStreamSynchronize(stream));
+    printf("tick2 advanced=%d  kvA=%d kvB=%d\n", adv2, batcher.peekKvCacheLength(laneA, stream),
+        batcher.peekKvCacheLength(laneB, stream));
+    if (adv2 != 2)
+    {
+        fprintf(stderr, "FATAL: tick2 expected to advance 2 lanes, got %d\n", adv2);
+        return 1;
+    }
+
+    auto LA_cc = batcher.getLogitsForTesting(laneA, stream);
+    auto LB_cc = batcher.getLogitsForTesting(laneB, stream);
+    CK(cudaStreamSynchronize(stream));
+
+    // Final CUDA-error scan across the concurrent run.
+    cudaError_t lastErr = cudaGetLastError();
+    bool cudaClean = (lastErr == cudaSuccess);
+    printf("CUDA last-error after concurrent run: %s => %s\n", cudaGetErrorString(lastErr),
+        cudaClean ? "CLEAN" : "ERROR");
+
+    batcher.evict(laneA, stream);
+    batcher.evict(laneB, stream);
+    CK(cudaStreamSynchronize(stream));
+
+    // ── THE ISOLATION GATE ───────────────────────────────────────────────────
+    printf("\n=== N=2 ASR ISOLATION GATE ===\n");
+    bool ok = cudaClean;
+
+    auto diffLane = [](std::vector<float> const& cc, std::vector<float> const& solo, char const* name) -> bool {
+        if (cc.empty() || solo.empty() || cc.size() != solo.size())
+        {
+            printf("lane %s: FAIL — logits empty / size mismatch (|cc|=%zu |solo|=%zu)\n", name, cc.size(),
+                solo.size());
+            return false;
+        }
+        double maxAbs = 0.0;
+        for (size_t i = 0; i < cc.size(); ++i)
+            maxAbs = std::max(maxAbs, std::fabs(static_cast<double>(cc[i]) - static_cast<double>(solo[i])));
+        int aCc = argmax(cc), aSolo = argmax(solo);
+        bool match = (aCc == aSolo) && (maxAbs < 1e-2);
+        printf("lane %s: argmax cc=%d solo=%d (%s)  max-abs diff = %.6e  => %s\n", name, aCc, aSolo,
+            aCc == aSolo ? "MATCH" : "MISMATCH", maxAbs, match ? "PASS" : "FAIL");
+        return match;
+    };
+
+    ok = diffLane(LA_cc, LA_solo, "A(0)") && ok;
+    ok = diffLane(LB_cc, LB_solo, "B(1)") && ok;
+    printf("0 CUDA errors across concurrent run: %s\n", cudaClean ? "YES" : "NO");
+
+    printf("\n=== M4 (N=2 ISOLATION) ACCEPTANCE: %s ===\n", ok ? "PASS" : "FAIL");
+    cudaStreamDestroy(stream);
+    return ok ? 0 : 1;
+}
