+#pragma once
+
+#include "common/tensor.h"
+#include "runtime/asrStreamingSessionRuntime.h" // SessionLaneManager / AsrSessionStatus / LaneOwnerKind
+#include "runtime/llmInferenceRuntime.h"
+#include "runtime/state/decodingInferenceContext.h"
+
+#include <cstdint>
+#include <deque>
+#include <mutex>
+#include <vector>
+
+namespace trt_edgellm
+{
+namespace rt
+{
+
+/*!
+ * @brief Continuous batch-lane scheduler for concurrent streaming-ASR sessions (spec §6 v2).
+ *
+ * v0.8.0's native request runtime fixes the admitted set at handleRequest entry and its decode
+ * loop ONLY evicts finished lanes (`compactBatch`, llmInferenceRuntime.cpp:~1611) — it never
+ * refills mid-loop, so async-arriving streaming sessions cannot ride it. AsrContinuousBatcher is
+ * the one net-new scheduling layer: it owns ONE shared DecodingInferenceContext sized to N lanes
+ * over the engine's native batch dimension, admits waiting sessions into free lanes, runs a
+ * RAGGED batched prefill-chunk step for the lanes that have a pending chunk this tick (reusing
+ * the existing `runBaseModelPrefillChunk` across the active batch via `appendPrefillChunk`),
+ * samples per-lane for finished lanes, and evicts finished lanes with the per-lane
+ * `resetSessionLane` (HybridCacheManager::resetLanes — memset, no reshape).
+ *
+ * Row<->lane invariant (codex-verified, file:line in PORT_NOTES): the shared context's row i is
+ * physical KV-cache batch row i AND MRope row i. `runBaseModelPrefillChunk` copies span[i] into
+ * IO row i, `commitSequenceLength` commits row i, and the RoPE kernel indexes
+ * `cosSinCacheBatchIdx=batchIdx` when the batch size is not 1 — so a batch-N prefill writes each
+ * lane's absolute position into its own KV/MRope row with zero cross-talk. This is the moat.
+ *
+ * Ragged-cadence rule (codex-verified): an IDLE lane MUST NOT be packed into the batched call —
+ * a zero/empty span yields `selectTokenIndices = ctxLen-1 = -1` in StepPreparer and the attention
+ * path still launches over the padded seq-len, corrupting that lane. So a tick batches ONLY the
+ * lanes that have a real pending chunk. The physical lane id IS the context row, and the prefill
+ * primitive implies row 0; therefore a lone surviving lane can be driven solo only when it is
+ * lane 0. (For the N=2 isolation gate both sessions share an identical chunk cadence, so every
+ * tick packs both lanes — activeBatchSize is always 2 — which is exactly the cross-talk test.)
+ *
+ * Single-token guard (v080-0004, batch-aware): the AttentionPlugin keys chunked-prefill vs decode
+ * on the BATCH-WIDE `qInputTensor.shape[1]` (= max chunk len across packed lanes). A tick is
+ * refused only when the MAX effective step length across the packed lanes is 1 while the KV cache
+ * is non-empty (would misroute the whole batch to the decode path). A mixed [1,5] tick is safe
+ * (shape[1]=5 keeps the whole batch on the chunked-prefill path; per-lane absolute KV-end indices
+ * are computed from kvCacheStartIdx + contextLength). Per-lane carry-over (deferring a trailing
+ * text token) is still applied so a producer that hands a lane a lone trailing token never forces
+ * a 1-token batch.
+ *
+ * Threading: a single internal mutex serializes admit/tick/evict (the shared PipelineIO is mutated
+ * by the engine step). Lockstep/serialized engine steps, not truly-parallel execution — see spec
+ * §5 "shared PipelineIO serialization".
+ */
+class AsrContinuousBatcher
+{
+public:
+    //! @brief One physical lane's streaming-ASR bookkeeping.
+    struct LaneRecord
+    {
+        int32_t lane{-1};                       //!< Physical batch row (== KV/MRope row). -1 if free.
+        int64_t sessionId{-1};                  //!< Caller session id.
+        AsrSessionStatus status{AsrSessionStatus::kIdle};
+        int32_t maxPositions{0};                //!< MRope/KV capacity this session was admitted for.
+        int32_t appendedTokens{0};              //!< Cumulative committed prefill tokens.
+        int32_t chunkCount{0};                  //!< Prefill steps committed so far.
+        std::vector<int32_t> pendingTextTail;   //!< Carried trailing text token (v080-0004 guard).
+        std::deque<std::vector<int32_t>> queue; //!< Pending text-only chunks (each with an isFinal flag in queueFinal).
+        std::deque<bool> queueFinal;            //!< isFinalChunk flag parallel to queue.
+    };
+
+    //! @param runtime Underlying request runtime (must outlive this; its engine must be maxBatchSize >= N).
+    //! @param laneManager Lane allocator (must outlive this); ASR lanes are acquired/released here.
+    AsrContinuousBatcher(LLMInferenceRuntime& runtime, SessionLaneManager& laneManager) noexcept;
+
+    AsrContinuousBatcher(AsrContinuousBatcher const&) = delete;
+    AsrContinuousBatcher& operator=(AsrContinuousBatcher const&) = delete;
+
+    //! @brief Admit a new streaming-ASR session into a free ASR lane.
+    //! @details Acquires a lane from the ASR partition, (re)initializes the SHARED batch context to
+    //!          cover all currently-admitted lanes, runs the one-shot prefill setup once, and inits
+    //!          the lane's MRope rows. The first admit sizes the context; a second admit re-runs
+    //!          setUp over the now-2-lane context. promptTokenIds may be empty (pure-token prefill).
+    //! @return Physical lane id, or -1 if the ASR partition is full / setup failed.
+    int32_t admit(int64_t sessionId, std::vector<int32_t> const& promptTokenIds, int32_t maxPositions,
+        cudaStream_t stream);
+
+    //! @brief Enqueue one text-only prefill chunk for an admitted lane.
+    //! @return False if the lane is unknown / already finished.
+    bool enqueueChunk(int32_t lane, std::vector<int32_t> const& chunkTokenIds, bool isFinalChunk);
+
+    //! @brief Run one scheduler step: ragged batched prefill over all lanes with a pending chunk.
+    //! @details Pops one chunk per ready lane, applies the per-lane carry-over guard, packs the
+    //!          ready lanes (in ascending row order) into a single `appendPrefillChunk` call,
+    //!          samples per-lane for lanes whose popped chunk is final, and advances per-lane state.
+    //!          Lanes whose final chunk was sampled transition to kFinished. Returns the number of
+    //!          lanes advanced (0 if nothing was pending).
+    //! @return Lanes advanced, or -1 on prefill failure / 1-token-batch refusal.
+    int32_t tick(cudaStream_t stream);
+
+    //! @brief Evict a finished (or any) lane: per-lane KV reset + release the lane.
+    void evict(int32_t lane, cudaStream_t stream);
+
+    // ── Introspection / testing surface ──────────────────────────────────────
+
+    //! @brief Active batch size of the shared context (number of admitted lanes).
+    int32_t activeBatchSize() const noexcept
+    {
+        return mContext.activeBatchSize;
+    }
+
+    AsrSessionStatus statusOf(int32_t lane) const;
+    int32_t appendedTokensOf(int32_t lane) const;
+    int32_t chunkCountOf(int32_t lane) const;
+
+    //! @brief Committed KV length for a lane (host-side, synchronous).
+    int32_t peekKvCacheLength(int32_t lane, cudaStream_t stream)
+    {
+        return mRuntime.peekKvCacheLength(lane, stream);
+    }
+
+    //! @brief Last-step logits row for a lane (parity surface for the isolation gate).
+    std::vector<float> getLogitsForTesting(int32_t lane, cudaStream_t stream)
+    {
+        return mRuntime.getLogitsForTesting(lane, stream);
+    }
+
+private:
+    LaneRecord* recordForLane(int32_t lane);
+    LaneRecord const* recordForLane(int32_t lane) const;
+
+    //! @brief (Re)build the shared context to cover the currently-admitted lanes (row==lane).
+    bool rebuildContext(cudaStream_t stream);
+
+    LLMInferenceRuntime& mRuntime;
+    SessionLaneManager& mLaneManager;
+    mutable std::mutex mMutex;
+
+    DecodingInferenceContext mContext;  //!< ONE shared context; row i == physical lane i.
+    std::vector<LaneRecord> mLanes;     //!< One record per admitted lane (ascending lane id).
+    std::vector<int32_t> mAdmittedLanes; //!< Admitted physical lane ids, ascending (== context rows).
+};
+
+} // namespace rt
+} // namespace trt_edgellm
