+
+AsrContinuousBatcher::AsrContinuousBatcher(LLMInferenceRuntime& runtime, SessionLaneManager& laneManager) noexcept
+    : mRuntime(runtime)
+    , mLaneManager(laneManager)
+{
+}
+
+AsrContinuousBatcher::LaneRecord* AsrContinuousBatcher::recordForLane(int32_t lane)
+{
+    for (auto& r : mLanes)
+    {
+        if (r.lane == lane)
+        {
+            return &r;
+        }
+    }
+    return nullptr;
+}
+
+AsrContinuousBatcher::LaneRecord const* AsrContinuousBatcher::recordForLane(int32_t lane) const
+{
+    for (auto const& r : mLanes)
+    {
+        if (r.lane == lane)
+        {
+            return &r;
+        }
+    }
+    return nullptr;
+}
+
+bool AsrContinuousBatcher::rebuildContext(cudaStream_t stream)
+{
+    // Row i of the shared context maps to physical lane mAdmittedLanes[i]. We require the admitted
+    // lanes to be the contiguous prefix {0,1,...,N-1} so that context row i == physical KV/MRope
+    // row i (the prefill primitive packs span[i] into IO row i and commits row i). The ASR lane
+    // partition starts at 0 and SessionLaneManager hands out ascending free lanes, so sequential
+    // ASR admits yield exactly this prefix.
+    int32_t const n = static_cast<int32_t>(mAdmittedLanes.size());
+    for (int32_t i = 0; i < n; ++i)
+    {
+        if (mAdmittedLanes[i] != i)
+        {
+            LOG_ERROR("AsrContinuousBatcher: admitted lanes must be the contiguous prefix {0..N-1} so "
+                      "context row i == physical lane i; got lane %d at row %d.",
+                mAdmittedLanes[i], i);
+            return false;
+        }
+    }
+
+    // (Re)initialize the shared context to cover all admitted lanes. initialize() sets
+    // activeBatchSize=batchSize and the identity batchIndexMapping.
+    mContext = DecodingInferenceContext{};
+    mContext.initialize(/*batchSize=*/n, /*maxGenLength=*/0, std::nullopt, rt::OptionalInputTensors{},
+        /*loraName=*/"", stream);
+
+    // Seed each lane's raw input ids (prompt prefix) and an empty system prompt so the one-shot
+    // setUp runs the cache-miss path (tokenIds = prompt, reuse=0, recurrent zeroed, KV reset for a
+    // new sequence) — exactly the state an append chunk expects, for every lane.
+    mContext.rawBatchedInputIds.clear();
+    for (int32_t i = 0; i < n; ++i)
+    {
+        // Lane records are kept in admission order; find the record for physical lane i.
+        LaneRecord const* rec = recordForLane(i);
+        mContext.rawBatchedInputIds.push_back(rec ? std::vector<int32_t>{} : std::vector<int32_t>{});
+        mContext.systemPrompts[i] = "";
+    }
+
+    if (!mRuntime.setUpAsrSessionPrefill(mContext))
+    {
+        LOG_ERROR("AsrContinuousBatcher: setUpAsrSessionPrefill failed for batch=%d", n);
+        return false;
+    }
+
+    // Init MRope rows for every admitted lane over [0, maxPositions).
+    for (int32_t i = 0; i < n; ++i)
+    {
+        LaneRecord const* rec = recordForLane(i);
+        int32_t const maxPos = rec ? rec->maxPositions : 0;
+        if (!mRuntime.initAsrSessionMRopeLane(i, maxPos, stream))
+        {
+            LOG_ERROR("AsrContinuousBatcher: MRope lane init failed for lane=%d maxPositions=%d", i, maxPos);
+            return false;
+        }
+    }
+    return true;
+}
+
+int32_t AsrContinuousBatcher::admit(
+    int64_t sessionId, std::vector<int32_t> const& promptTokenIds, int32_t maxPositions, cudaStream_t stream)
+{
+    std::lock_guard<std::mutex> lock(mMutex);
+
+    int32_t const lane = mLaneManager.acquire(LaneOwnerKind::kAsr, sessionId);
+    if (lane < 0)
+    {
+        LOG_ERROR("AsrContinuousBatcher::admit: no free ASR lane for session %ld", static_cast<long>(sessionId));
+        return -1;
+    }
+    if (lane >= mRuntime.cacheManagerMaxBatchSize())
+    {
+        LOG_ERROR("AsrContinuousBatcher::admit: lane %d exceeds cache maxBatchSize %d", lane,
+            mRuntime.cacheManagerMaxBatchSize());
+        mLaneManager.release(lane);
+        return -1;
+    }
+
+    LaneRecord rec;
+    rec.lane = lane;
+    rec.sessionId = sessionId;
+    rec.status = AsrSessionStatus::kActive;
+    rec.maxPositions = maxPositions;
+    mLanes.push_back(std::move(rec));
+    mAdmittedLanes.push_back(lane);
+    std::sort(mAdmittedLanes.begin(), mAdmittedLanes.end());
+
+    // Rebuild the shared context to cover the new lane set. NOTE: this re-runs the one-shot prefill
+    // setUp, which resets KV lengths for the whole active batch — admit-before-any-append is the
+    // contract (the isolation gate admits both lanes up-front, then appends). promptTokenIds is
+    // captured in the lane record's first queued chunk if non-empty.
+    if (!rebuildContext(stream))
+    {
+        // Roll back the admission.
+        mLanes.pop_back();
+        mAdmittedLanes.erase(std::find(mAdmittedLanes.begin(), mAdmittedLanes.end(), lane));
+        mLaneManager.release(lane);
+        return -1;
+    }
+
+    if (!promptTokenIds.empty())
+    {
+        LaneRecord* live = recordForLane(lane);
+        live->queue.push_back(promptTokenIds);
+        live->queueFinal.push_back(false);
+    }
+
+    LOG_INFO("AsrContinuousBatcher::admit: session %ld -> lane %d (activeBatch=%d, maxPositions=%d)",
+        static_cast<long>(sessionId), lane, mContext.activeBatchSize, maxPositions);
+    return lane;
+}
+
+bool AsrContinuousBatcher::enqueueChunk(int32_t lane, std::vector<int32_t> const& chunkTokenIds, bool isFinalChunk)
+{
+    std::lock_guard<std::mutex> lock(mMutex);
+    LaneRecord* rec = recordForLane(lane);
+    if (rec == nullptr || rec->status != AsrSessionStatus::kActive)
+    {
+        LOG_ERROR("AsrContinuousBatcher::enqueueChunk: lane %d unknown or not active", lane);
+        return false;
+    }
+    if (chunkTokenIds.empty())
+    {
+        LOG_ERROR("AsrContinuousBatcher::enqueueChunk: empty chunk for lane %d", lane);
+        return false;
+    }
+    rec->queue.push_back(chunkTokenIds);
+    rec->queueFinal.push_back(isFinalChunk);
+    return true;
+}
+
+int32_t AsrContinuousBatcher::tick(cudaStream_t stream)
+{
+    std::lock_guard<std::mutex> lock(mMutex);
+
+    // Collect the lanes (ascending == context-row order) that have a pending chunk this tick, and
+    // build each one's effective step tokens with the v080-0004 per-lane carry-over guard.
+    struct Ready
+    {
+        int32_t row;                    // context row == physical lane id
+        LaneRecord* rec;
+        std::vector<int32_t> stepTokens;
+        std::vector<int32_t> nextTail;  // committed to rec->pendingTextTail on success
+        bool isFinal;
+        bool priorKvNonEmpty;
+    };
+    std::vector<Ready> ready;
+
+    for (int32_t row = 0; row < static_cast<int32_t>(mAdmittedLanes.size()); ++row)
+    {
+        int32_t const lane = mAdmittedLanes[row];
+        LaneRecord* rec = recordForLane(lane);
+        if (rec == nullptr || rec->status != AsrSessionStatus::kActive || rec->queue.empty())
+        {
+            continue; // idle lane — MUST NOT be packed (empty span corrupts it).
+        }
+
+        std::vector<int32_t> const chunk = rec->queue.front();
+        bool const isFinal = rec->queueFinal.front();
+        rec->queue.pop_front();
+        rec->queueFinal.pop_front();
+
+        bool const priorKvNonEmpty = (rec->chunkCount > 0) || !rec->pendingTextTail.empty();
+
+        // Prepend any carried text tail (text-only sessions in this scheduler).
+        std::vector<int32_t> effective;
+        if (!rec->pendingTextTail.empty())
+        {
+            effective.reserve(rec->pendingTextTail.size() + chunk.size());
+            effective.insert(effective.end(), rec->pendingTextTail.begin(), rec->pendingTextTail.end());
+            effective.insert(effective.end(), chunk.begin(), chunk.end());
+        }
+        else
+        {
+            effective = chunk;
+        }
+
+        // Defer the trailing token of a non-final chunk so the NEXT step packs >= 2 tokens.
+        bool const deferTail = (!isFinal && effective.size() >= 2);
+        Ready r;
+        r.row = row;
+        r.rec = rec;
+        r.isFinal = isFinal;
+        r.priorKvNonEmpty = priorKvNonEmpty;
+        if (deferTail)
+        {
+            r.nextTail.assign(effective.end() - 1, effective.end());
+            r.stepTokens.assign(effective.begin(), effective.end() - 1);
+        }
+        else
+        {
+            r.stepTokens = std::move(effective);
+        }
+
+        // Per-lane capacity guard.
+        if (rec->maxPositions > 0
+            && rec->appendedTokens + static_cast<int32_t>(r.stepTokens.size()) > rec->maxPositions)
+        {
+            LOG_ERROR("AsrContinuousBatcher::tick: lane %d would exceed capacity (appended=%d + step=%zu > %d)", lane,
+                rec->appendedTokens, r.stepTokens.size(), rec->maxPositions);
+            // Put the original chunk back (refusal-safe — carry state untouched).
+            rec->queue.push_front(chunk);
+            rec->queueFinal.push_front(isFinal);
+            return -1;
+        }
+        ready.push_back(std::move(r));
+    }
+
+    if (ready.empty())
+    {
+        return 0; // nothing pending.
+    }
+
+    // The packed lanes must be the contiguous prefix {0..k-1} so context row i == span index i.
+    // (For the isolation gate every lane is ready every tick → packs {0,1}.) A non-prefix ready
+    // set (e.g. only lane 1 pending) cannot be driven by this primitive — row 0 is implied.
+    for (int32_t i = 0; i < static_cast<int32_t>(ready.size()); ++i)
+    {
+        if (ready[i].row != i)
+        {
+            LOG_ERROR("AsrContinuousBatcher::tick: ready lanes must form the prefix {0..k-1}; row %d at index %d. "
+                      "A lone non-zero lane needs compaction (not implemented for the isolation gate).",
+                ready[i].row, i);
+            return -1;
+        }
+    }
+
+    // Batch-wide single-token guard: the AttentionPlugin keys chunked-prefill vs decode on the
+    // batch-wide max chunk len. Refuse the tick if the max effective step len is 1 while ANY packed
+    // lane has a non-empty KV cache (would misroute the whole batch to the decode path).
+    int32_t maxStepLen = 0;
+    bool anyPriorKv = false;
+    bool anyFinal = false;
+    for (auto const& r : ready)
+    {
+        maxStepLen = std::max(maxStepLen, static_cast<int32_t>(r.stepTokens.size()));
+        anyPriorKv = anyPriorKv || r.priorKvNonEmpty;
+        anyFinal = anyFinal || r.isFinal;
+    }
+    if (maxStepLen == 1 && anyPriorKv)
+    {
+        LOG_ERROR("AsrContinuousBatcher::tick: refusing a max-1-token batched prefill step on a non-empty KV cache "
+                  "(would misroute the whole batch to the decode path).");
+        return -1;
+    }
+
+    // The context's activeBatchSize must equal the number of packed lanes. For the isolation gate
+    // this is the full admitted batch. (If a subset is ready, we would need to temporarily set
+    // activeBatchSize to k; the prefix invariant above guarantees rows 0..k-1 map correctly.)
+    int32_t const packed = static_cast<int32_t>(ready.size());
+    mContext.activeBatchSize = packed;
+
+    std::vector<rt::SpanI32> spans;
+    spans.reserve(packed);
+    for (auto& r : ready)
+    {
+        spans.emplace_back(r.stepTokens.data(), r.stepTokens.size());
+    }
+
+    // Sample only when at least one packed lane's chunk is final. (The isolation gate uses a single
+    // final tick so this samples the comparison logits for both lanes simultaneously.)
+    bool const sampleAfterPrefill = anyFinal;
+    if (!mRuntime.appendPrefillChunk(mContext, spans, /*audioEmbeds=*/std::nullopt, sampleAfterPrefill))
+    {
+        LOG_ERROR("AsrContinuousBatcher::tick: appendPrefillChunk failed (packed=%d)", packed);
+        return -1;
+    }
+
+    // Commit per-lane state now that the prefill succeeded.
+    for (auto& r : ready)
+    {
+        r.rec->pendingTextTail = std::move(r.nextTail);
+        r.rec->appendedTokens += static_cast<int32_t>(r.stepTokens.size());
+        ++r.rec->chunkCount;
+        mLaneManager.setKvLength(r.rec->lane, r.rec->appendedTokens);
+        if (r.isFinal)
+        {
+            r.rec->status = AsrSessionStatus::kFinished;
+        }
+    }
+    return packed;
+}
+
+void AsrContinuousBatcher::evict(int32_t lane, cudaStream_t stream)
+{
+    std::lock_guard<std::mutex> lock(mMutex);
+    LaneRecord* rec = recordForLane(lane);
+    if (rec == nullptr)
+    {
+        return;
+    }
+    // Per-lane teardown: memset only this lane's KV length (no reshape), then release the lane.
+    mRuntime.resetSessionLane(lane, stream);
+    mLaneManager.release(lane);
+
+    mLanes.erase(std::remove_if(mLanes.begin(), mLanes.end(), [lane](LaneRecord const& r) { return r.lane == lane; }),
+        mLanes.end());
+    mAdmittedLanes.erase(std::remove(mAdmittedLanes.begin(), mAdmittedLanes.end(), lane), mAdmittedLanes.end());
+    // Shrink the logical active batch to the surviving lanes (rows 0..N-1).
+    mContext.activeBatchSize = static_cast<int32_t>(mAdmittedLanes.size());
+}
+
+AsrSessionStatus AsrContinuousBatcher::statusOf(int32_t lane) const
+{
+    std::lock_guard<std::mutex> lock(mMutex);
+    LaneRecord const* rec = recordForLane(lane);
+    return rec ? rec->status : AsrSessionStatus::kIdle;
+}
+
+int32_t AsrContinuousBatcher::appendedTokensOf(int32_t lane) const
+{
+    std::lock_guard<std::mutex> lock(mMutex);
+    LaneRecord const* rec = recordForLane(lane);
+    return rec ? rec->appendedTokens : 0;
+}
+
+int32_t AsrContinuousBatcher::chunkCountOf(int32_t lane) const
+{
+    std::lock_guard<std::mutex> lock(mMutex);
+    LaneRecord const* rec = recordForLane(lane);
+    return rec ? rec->chunkCount : 0;
+}
+
+} // namespace rt
+} // namespace trt_edgellm
