+bool LLMInferenceRuntime::decodeAsrSessionToCompletion(DecodingInferenceContext& context)
+{
+    // ASR thinker engines are non-speculative, so cachePrimingStrategy() resolves to the default
+    // (vanilla) decoder — the same strategy the one-shot path would select for a greedy ASR request.
+    // decodeToCompletion drives kVANILLA_DECODING decodeStep to EOS; the v080-0004 single-token
+    // chunk guard is prefill-only and never applies to these decode steps.
+    DecodingStrategy& strategy = mDecoderRegistry->cachePrimingStrategy();
+    return decodeToCompletion(context, strategy);
+}
+
+std::string LLMInferenceRuntime::getAsrSessionTranscript(DecodingInferenceContext& context) const
+{
+    if (context.completedBatches.empty())
+    {
+        LOG_ERROR("getAsrSessionTranscript: no completed batch (did you call decodeAsrSessionToCompletion?)");
+        return {};
+    }
+    // Single-session/single-lane: take the first (only) completed batch and extract the generated
+    // suffix exactly as handleRequest does for response.outputTexts.
+    auto const& batchResult = context.completedBatches.begin()->second;
+    int32_t const genLength = batchResult.generateLength;
+    int32_t const totalLength = static_cast<int32_t>(batchResult.tokenIds.size());
+    if (totalLength < genLength || genLength <= 0)
+    {
+        LOG_ERROR("getAsrSessionTranscript: invalid lengths total=%d gen=%d", totalLength, genLength);
+        return {};
+    }
+    std::vector<int32_t> const generatedIds(
+        batchResult.tokenIds.begin() + (totalLength - genLength), batchResult.tokenIds.end());
+    return mTokenizer->decode(generatedIds, /*skipSpecialTokens=*/true);
+}
