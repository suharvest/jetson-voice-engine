diff --git a/examples/llm/spike_v080_m6_audio_streaming.cpp b/examples/llm/spike_v080_m6_audio_streaming.cpp
--- a/examples/llm/spike_v080_m6_audio_streaming.cpp
+++ b/examples/llm/spike_v080_m6_audio_streaming.cpp
@@ -0,0 +1,244 @@
+// Phase 3c empirical spike — REAL AUDIO end-to-end through the v0.8.0 streaming-ASR
+// runtime to a decoded transcript (the genuine remaining gap closed by patch v080-0012).
+//
+// Pipeline exercised:
+//   beginAsrSession(prompt prefix) → appendChunk(audio-pad slice + mel chunk(s)) →
+//   final appendChunk (sampleAfterPrefill) → mRuntime.decodeAsrSessionToCompletion
+//   (decodeToCompletion: autoregressive decode to EOS) → getAsrSessionTranscript →
+//   getTranscript().
+//
+// Two modes:
+//   --chunks 1   (default): the WHOLE WAV mel is fed as a SINGLE final audio chunk. This
+//                isolates the DECODE-to-transcript hook on real audio (no chunk-boundary
+//                question). Transcript MUST match the v0.7.1 golden (CER, after harness
+//                normalize done by the python wrapper).
+//   --chunks K>1: the mel is split into K contiguous windows (the .cN safetensors emitted
+//                by gen_mel_np.py) and fed as K appendChunk calls, interleaving the ASR
+//                prompt prefix on chunk 0 and audio_end + assistant suffix on the final
+//                chunk. Tests streaming(chunked) == oneshot(single) self-consistency.
+//
+// Prompt token layout (Qwen3-ASR, IDs verified against the engine tokenizer.json + config.json):
+//   prefix  = <|im_start|>user\n           = [151644, 872, 198]
+//   audio   = <|audio_start|> Nx<|audio_pad|> <|audio_end|> = [151669, (151676)*N, 151670]
+//   suffix  = <|im_end|>\n<|im_start|>assistant\n = [151645, 198, 151644, 77091, 198]
+// audio_token_id (151676), audio_start (151669), audio_end (151670) are read here as
+// constants; the runtime's embedding preprocessor binds the per-chunk audio embeddings to the
+// 151676 positions (audio_token_id from config.json).
+
+#include "common/tensor.h"
+#include "common/trtUtils.h"
+#include "runtime/asrStreamingSessionRuntime.h"
+#include "runtime/audioUtils.h"
+#include "runtime/llmInferenceRuntime.h"
+
+#include <cuda_runtime.h>
+
+#include <cstdint>
+#include <cstdio>
+#include <cstdlib>
+#include <cstring>
+#include <memory>
+#include <string>
+#include <unordered_map>
+#include <vector>
+
+using namespace trt_edgellm;
+
+#define CK(x)                                                                                                          \
+    do                                                                                                                 \
+    {                                                                                                                  \
+        auto _e = (x);                                                                                                 \
+        if (_e != cudaSuccess)                                                                                         \
+        {                                                                                                              \
+            fprintf(stderr, "CUDA err %s:%d %s\n", __FILE__, __LINE__, cudaGetErrorString(_e));                       \
+            std::exit(2);                                                                                              \
+        }                                                                                                              \
+    } while (0)
+
+namespace
+{
+constexpr int32_t kImStart = 151644;
+constexpr int32_t kUser = 872;
+constexpr int32_t kNl = 198;
+constexpr int32_t kAudioStart = 151669;
+constexpr int32_t kAudioPad = 151676;
+constexpr int32_t kAudioEnd = 151670;
+constexpr int32_t kImEnd = 151645;
+constexpr int32_t kAssistant = 77091;
+
+// Probe a mel chunk through the audio encoder to learn how many audio tokens (151676 pads)
+// it produces. Reshapes `scratch` to [N, featureDim]; returns N.
+int32_t probeAudioTokens(rt::LLMInferenceRuntime& rt, std::string const& melPath, rt::Tensor& scratch,
+    cudaStream_t stream)
+{
+    rt::audioUtils::AudioData mel;
+    mel.melSpectrogramPath = melPath;
+    mel.melSpectrogramFormat = "safetensors";
+    if (!rt.encodeAudioChunk(mel, scratch, stream))
+    {
+        fprintf(stderr, "probeAudioTokens: encodeAudioChunk failed for %s\n", melPath.c_str());
+        return -1;
+    }
+    CK(cudaStreamSynchronize(stream));
+    return static_cast<int32_t>(scratch.getShape()[0]);
+}
+
+rt::AudioChunk makeAudioChunk(std::string const& melPath)
+{
+    rt::AudioChunk c;
+    c.data.melSpectrogramPath = melPath;
+    c.data.melSpectrogramFormat = "safetensors";
+    c.hasAudio = true;
+    return c;
+}
+} // namespace
+
+int main(int argc, char** argv)
+{
+    std::string llmDir = "/home/harvest/tensorrt-edgellm-workspace/Qwen3-ASR-0.6B/engines-v080/llm";
+    std::string audioDir = "/home/harvest/tensorrt-edgellm-workspace/Qwen3-ASR-0.6B/engines-v080/audio";
+    std::string melPath; // full-WAV mel safetensors (single-chunk mode)
+    int32_t numChunks = 1;
+    int32_t maxGenLen = 256;
+    int32_t maxAudioTokensPerChunk = 2048; // worst-case sizing for the per-chunk scratch
+
+    for (int i = 1; i < argc; ++i)
+    {
+        std::string a = argv[i];
+        auto next = [&]() -> std::string { return (i + 1 < argc) ? argv[++i] : std::string{}; };
+        if (a == "--llm")
+            llmDir = next();
+        else if (a == "--audio")
+            audioDir = next();
+        else if (a == "--mel")
+            melPath = next();
+        else if (a == "--chunks")
+            numChunks = std::atoi(next().c_str());
+        else if (a == "--max-gen")
+            maxGenLen = std::atoi(next().c_str());
+        else if (a == "--max-audio-tokens")
+            maxAudioTokensPerChunk = std::atoi(next().c_str());
+    }
+    if (melPath.empty())
+    {
+        fprintf(stderr, "usage: %s --mel <full.safetensors> [--chunks K] [--llm DIR] [--audio DIR]\n", argv[0]);
+        fprintf(stderr, "  --chunks 1 uses --mel directly; --chunks K reads <mel>.c0 .. <mel>.c{K-1}\n");
+        return 2;
+    }
+
+    auto pluginHandles = loadEdgellmPluginLib();
+    cudaStream_t stream;
+    CK(cudaStreamCreate(&stream));
+
+    std::unordered_map<std::string, std::string> loraMap;
+    std::unique_ptr<rt::LLMInferenceRuntime> runtime;
+    try
+    {
+        runtime = std::make_unique<rt::LLMInferenceRuntime>(llmDir, audioDir, loraMap, stream);
+    }
+    catch (std::exception const& e)
+    {
+        fprintf(stderr, "FATAL: runtime construction failed: %s\n", e.what());
+        return 2;
+    }
+    printf("runtime constructed (llm=%s audio=%s)\n", llmDir.c_str(), audioDir.c_str());
+    printf("maxSessionBatchSize=%d  chunks=%d  maxGenLen=%d\n", runtime->maxSessionBatchSize(), numChunks, maxGenLen);
+
+    // Driver-side scratch used only to PROBE per-chunk audio-token counts (re-encoded inside
+    // appendChunk for the real binding). Sized to the worst case once.
+    rt::Tensor probeScratch;
+    if (!runtime->allocateChunkAudioEmbedding(probeScratch, maxAudioTokensPerChunk))
+    {
+        fprintf(stderr, "FATAL: allocateChunkAudioEmbedding failed\n");
+        return 2;
+    }
+
+    // Resolve per-chunk mel paths + probe their audio-token counts.
+    std::vector<std::string> melPaths;
+    if (numChunks <= 1)
+    {
+        melPaths.push_back(melPath);
+    }
+    else
+    {
+        for (int i = 0; i < numChunks; ++i)
+            melPaths.push_back(melPath + ".c" + std::to_string(i));
+    }
+    std::vector<int32_t> nTokens(melPaths.size(), 0);
+    int32_t totalAudioTokens = 0;
+    for (size_t i = 0; i < melPaths.size(); ++i)
+    {
+        nTokens[i] = probeAudioTokens(*runtime, melPaths[i], probeScratch, stream);
+        if (nTokens[i] < 0)
+            return 1;
+        totalAudioTokens += nTokens[i];
+        printf("chunk %zu mel=%s -> audioTokens=%d\n", i, melPaths[i].c_str(), nTokens[i]);
+    }
+    printf("total audio tokens across %zu chunk(s) = %d\n", melPaths.size(), totalAudioTokens);
+
+    // maxPositions must cover prefix + audio_start + N pads + audio_end + suffix (+ slack).
+    int32_t const maxPositions = totalAudioTokens + 64;
+
+    rt::AsrStreamingSessionRuntime sess(*runtime, /*lane*/ 0);
+    if (!sess.beginAsrSession(/*promptTokenIds*/ {}, maxPositions, maxAudioTokensPerChunk, stream, maxGenLen))
+    {
+        fprintf(stderr, "FATAL: beginAsrSession failed\n");
+        return 1;
+    }
+
+    // Feed chunks. Chunk 0 carries the prompt prefix + audio_start; the final chunk carries
+    // audio_end + the assistant suffix and triggers decodeToCompletion.
+    int32_t const lastIdx = static_cast<int32_t>(melPaths.size()) - 1;
+    for (int32_t i = 0; i <= lastIdx; ++i)
+    {
+        std::vector<int32_t> slice;
+        if (i == 0)
+        {
+            slice.push_back(kImStart);
+            slice.push_back(kUser);
+            slice.push_back(kNl);
+            slice.push_back(kAudioStart);
+        }
+        for (int32_t k = 0; k < nTokens[i]; ++k)
+            slice.push_back(kAudioPad);
+        if (i == lastIdx)
+        {
+            slice.push_back(kAudioEnd);
+            slice.push_back(kImEnd);
+            slice.push_back(kNl);
+            slice.push_back(kImStart);
+            slice.push_back(kAssistant);
+            slice.push_back(kNl);
+        }
+        rt::AudioChunk chunk = makeAudioChunk(melPaths[i]);
+        bool const isFinal = (i == lastIdx);
+        if (!sess.appendChunk(slice, chunk, isFinal, stream))
+        {
+            fprintf(stderr, "FATAL: appendChunk %d (final=%d, sliceLen=%zu) failed\n", i, isFinal, slice.size());
+            return 1;
+        }
+        CK(cudaStreamSynchronize(stream));
+        printf("appended chunk %d (final=%d) sliceLen=%zu kv=%d\n", i, isFinal, slice.size(),
+            sess.peekKvCacheLength(stream));
+    }
+
+    if (sess.status() != rt::AsrSessionStatus::kFinished)
+    {
+        fprintf(stderr, "FATAL: session not finished after final chunk (status=%d)\n",
+            static_cast<int32_t>(sess.status()));
+        return 1;
+    }
+
+    // Explicit decode-to-EOS step (this evicts the lane, so peekKvCacheLength was read above).
+    if (!sess.decodeToTranscript(stream))
+    {
+        fprintf(stderr, "FATAL: decodeToTranscript failed\n");
+        return 1;
+    }
+    std::string const transcript = sess.getTranscript();
+    printf("\n=== TRANSCRIPT (chunks=%d) ===\n%s\n=== END TRANSCRIPT ===\n", numChunks, transcript.c_str());
+
+    sess.endAsrSession(stream);
+    cudaStreamDestroy(stream);
+    return transcript.empty() ? 1 : 0;
+}

