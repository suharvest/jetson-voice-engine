+AsrStreamingSessionRuntime::AsrStreamingSessionRuntime(LLMInferenceRuntime& runtime, int32_t lane) noexcept
+    : mRuntime(runtime)
+    , mLane(lane)
+{
+}
+
+bool AsrStreamingSessionRuntime::beginAsrSession(
+    std::vector<int32_t> const& promptTokenIds, int32_t maxPositions, int32_t maxAudioTokensPerChunk, cudaStream_t stream)
+{
+    if (mStatus != AsrSessionStatus::kIdle)
+    {
+        LOG_ERROR("beginAsrSession: a session is already active (status=%d); call endAsrSession first.",
+            static_cast<int32_t>(mStatus));
+        return false;
+    }
+
+    int32_t const maxBatch = mRuntime.maxSessionBatchSize();
+    if (mLane < 0 || mLane >= maxBatch)
+    {
+        LOG_ERROR("beginAsrSession: lane=%d out of range [0, %d)", mLane, maxBatch);
+        return false;
+    }
+
+    // Phase 3: a single session over a single active lane. Initialize a fresh context with
+    // activeBatchSize=1 mapped to lane 0 of the runtime's tensors. (Multi-lane mapping is Phase 4.)
+    mContext = DecodingInferenceContext{};
+    mContext.initialize(/*batchSize=*/1, /*maxGenLength=*/0, std::nullopt, rt::OptionalInputTensors{},
+        /*loraName=*/"", stream);
+
+    // Seed raw input IDs with the prompt prefix so setUpForPrefillExecution computes correct
+    // sys-prompt-cache reuse / cache lengths. The system prompt string is left empty (ASR drives
+    // tokens directly), so the cache-miss path runs: tokenIds = prompt, reuse=0, recurrent zeroed,
+    // and the KV cache is reset for a new sequence — exactly the state an append chunk expects.
+    mContext.rawBatchedInputIds.clear();
+    mContext.rawBatchedInputIds.push_back(promptTokenIds);
+    mContext.systemPrompts[0] = "";
+
+    if (!mRuntime.setUpAsrSessionPrefill(mContext))
+    {
+        LOG_ERROR("beginAsrSession: setUpForPrefillExecution failed");
+        return false;
+    }
+
+    // Initialize the MRope cos/sin cache for this lane over [0, maxPositions) WITHOUT reshaping the
+    // shared PipelineIO buffer (Phase 2 patch). No-op for non-MRope / non-audio runtimes.
+    if (!mRuntime.initAsrSessionMRopeLane(mLane, maxPositions, stream))
+    {
+        LOG_ERROR("beginAsrSession: MRope lane init failed for lane=%d maxPositions=%d", mLane, maxPositions);
+        return false;
+    }
+
+    // Pre-allocate the reusable per-chunk audio-embedding scratch (FP16, sized to the worst-case
+    // chunk). Skipped for text-only sessions (maxAudioTokensPerChunk == 0).
+    if (maxAudioTokensPerChunk > 0)
+    {
+        if (!mRuntime.allocateChunkAudioEmbedding(mChunkAudioEmbedding, maxAudioTokensPerChunk))
+        {
+            LOG_ERROR("beginAsrSession: failed to allocate per-chunk audio embedding scratch (tokens=%d)",
+                maxAudioTokensPerChunk);
+            return false;
+        }
+    }
+
+    mMaxPositions = maxPositions;
+    mAppendedTokens = 0;
+    mChunkCount = 0;
+    mStatus = AsrSessionStatus::kActive;
+    LOG_INFO("beginAsrSession: lane=%d maxPositions=%d promptTokens=%zu", mLane, maxPositions, promptTokenIds.size());
+    return true;
+}
+
+bool AsrStreamingSessionRuntime::appendChunk(
+    std::vector<int32_t> const& chunkTokenIds, AudioChunk const& mel, bool isFinalChunk, cudaStream_t stream)
+{
+    return appendChunkImpl(chunkTokenIds, mel.hasAudio ? &mel.data : nullptr, isFinalChunk, stream);
+}
+
+bool AsrStreamingSessionRuntime::appendChunk(
+    std::vector<int32_t> const& chunkTokenIds, bool isFinalChunk, cudaStream_t stream)
+{
+    return appendChunkImpl(chunkTokenIds, /*mel=*/nullptr, isFinalChunk, stream);
+}
+
+bool AsrStreamingSessionRuntime::appendChunkImpl(std::vector<int32_t> const& chunkTokenIds,
+    rt::audioUtils::AudioData const* mel, bool isFinalChunk, cudaStream_t stream)
+{
+    if (mStatus != AsrSessionStatus::kActive)
+    {
+        LOG_ERROR("appendChunk: no active session (status=%d)", static_cast<int32_t>(mStatus));
+        return false;
+    }
+
+    if (chunkTokenIds.empty())
+    {
+        LOG_ERROR("appendChunk: empty chunk token slice");
+        return false;
+    }
+
+    // Overflow guard: this chunk must not push the cumulative positions past the MRope/KV capacity
+    // the session was initialized for (spec R3 invariant).
+    if (mMaxPositions > 0 && mAppendedTokens + static_cast<int32_t>(chunkTokenIds.size()) > mMaxPositions)
+    {
+        LOG_ERROR("appendChunk: chunk would exceed session capacity (appended=%d + chunk=%zu > maxPositions=%d)",
+            mAppendedTokens, chunkTokenIds.size(), mMaxPositions);
+        return false;
+    }
+
+    // Encode the mel chunk (if any) into a per-chunk audio embedding buffer and bind it for THIS
+    // chunk's embedding lookup. Text-only chunks pass no audio embeddings.
+    rt::OptionalInputTensor audioEmbeds = std::nullopt;
+    if (mel != nullptr)
+    {
+        if (!mRuntime.encodeAudioChunk(*mel, mChunkAudioEmbedding, stream))
+        {
+            LOG_ERROR("appendChunk: audio chunk encode failed");
+            return false;
+        }
+        audioEmbeds = std::optional<std::reference_wrapper<rt::Tensor const>>(std::cref(mChunkAudioEmbedding));
+    }
+
+    // Append-only prefill: pack ONLY this chunk's slice onto the committed KV cache. Sampling is
+    // enabled only on the final chunk.
+    std::vector<rt::SpanI32> chunkSpans;
+    chunkSpans.emplace_back(chunkTokenIds.data(), chunkTokenIds.size());
+    if (!mRuntime.appendPrefillChunk(mContext, chunkSpans, audioEmbeds, /*sampleAfterPrefill=*/isFinalChunk))
+    {
+        LOG_ERROR("appendChunk: prefill chunk %d failed", mChunkCount);
+        return false;
+    }
+
+    mAppendedTokens += static_cast<int32_t>(chunkTokenIds.size());
+    ++mChunkCount;
+    if (isFinalChunk)
+    {
+        mStatus = AsrSessionStatus::kFinished;
+    }
+    return true;
+}
+
+void AsrStreamingSessionRuntime::endAsrSession(cudaStream_t stream)
+{
+    if (mStatus == AsrSessionStatus::kIdle)
+    {
+        return;
+    }
+    // Phase 3: full-batch reset (single session/lane). TODO(phase4): per-lane reset.
+    mRuntime.resetForSessionEnd(stream);
+    mContext = DecodingInferenceContext{};
+    mMaxPositions = 0;
+    mAppendedTokens = 0;
+    mChunkCount = 0;
+    mStatus = AsrSessionStatus::kIdle;
+}
+
+} // namespace rt
+} // namespace trt_edgellm
