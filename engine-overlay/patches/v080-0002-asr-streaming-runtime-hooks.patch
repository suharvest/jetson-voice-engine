+
+namespace trt_edgellm
+{
+namespace rt
+{
+
+//! @brief Lifecycle state of a streaming-ASR session.
+enum class AsrSessionStatus
+{
+    kIdle,    //!< No active session (before begin / after end).
+    kActive,  //!< Session begun; ready to accept prefill chunks.
+    kFinished //!< Final chunk appended (token sampled); awaiting end.
+};
+
+//! @brief Carrier for an optional mel chunk passed to appendChunk.
+//! @details A thin wrapper around rt::audioUtils::AudioData so callers describe a chunk's
+//!          pre-computed mel path/format without the runtime imposing an audio pipeline.
+struct AudioChunk
+{
+    rt::audioUtils::AudioData data; //!< Pre-computed mel-spectrogram descriptor.
+    bool hasAudio{false};           //!< When false, the chunk is text-only.
+};
+
+/*!
+ * @brief Composition wrapper that turns the one-shot LLMInferenceRuntime into a
+ *        chunked streaming-ASR session (spec §6.2 / §2).
+ *
+ * This is deliberately NOT a DecodingStrategy: strategies own the post-prefill
+ * decode + draft cache, whereas streaming ASR needs INCREMENTAL prefill BEFORE
+ * any decode. Instead this wrapper drives the narrow ASR hooks on
+ * LLMInferenceRuntime (encodeAudioChunk / appendPrefillChunk / setUpAsrSessionPrefill /
+ * initAsrSessionMRopeLane / peekKvCacheLength / resetForSessionEnd) and owns the
+ * per-session DecodingInferenceContext + lane + MRope position cursor.
+ *
+ * Phase 3 supports a SINGLE session over a single lane; end-of-session uses the
+ * existing full-batch reset. Multi-lane reset / concurrent sessions are Phase 4
+ * (spec R1) — see TODO(phase4) in LLMInferenceRuntime::resetForSessionEnd.
+ *
+ * Threading: not internally synchronized. The owning runtime's shared PipelineIO
+ * is mutated by appendPrefillChunk, so concurrent sessions on one runtime must be
+ * serialized by the caller (spec §5 "shared PipelineIO serialization").
+ */
+class AsrStreamingSessionRuntime
+{
+public:
+    //! @param runtime The underlying request runtime (must outlive this wrapper).
+    //! @param lane    Physical batch lane this session occupies (Phase 3: 0).
+    explicit AsrStreamingSessionRuntime(LLMInferenceRuntime& runtime, int32_t lane = 0) noexcept;
+
+    AsrStreamingSessionRuntime(AsrStreamingSessionRuntime const&) = delete;
+    AsrStreamingSessionRuntime& operator=(AsrStreamingSessionRuntime const&) = delete;
+
+    //! @brief Begin a streaming-ASR session.
+    //! @details Mirrors handleRequest after multimodal formatting: initializes the session
+    //!          DecodingInferenceContext, runs setUpForPrefillExecution ONCE (LoRA / sys-prompt
+    //!          KV reuse / recurrent-zero / cache-length reset), and initializes the MRope lane
+    //!          over [0, maxPositions). Does NOT preprocess one-shot audio. Prefill chunks are
+    //!          fed via appendChunk.
+    //! @param promptTokenIds Pre-tokenized prompt prefix for the lane (e.g. ASR system/template
+    //!                       tokens). May be empty for a pure-audio prefill.
+    //! @param maxPositions   Upper bound on cumulative audio+text positions this session will
+    //!                       reach; validated against the MRope cache + KV capacity.
+    //! @param maxAudioTokensPerChunk Upper bound on audio tokens a single chunk's mel can produce;
+    //!                       sizes the reusable per-chunk audio-embedding scratch. Pass 0 for a
+    //!                       text-only session (no audio scratch allocated).
+    //! @param stream         CUDA stream.
+    //! @return True on success, false otherwise.
+    bool beginAsrSession(std::vector<int32_t> const& promptTokenIds, int32_t maxPositions,
+        int32_t maxAudioTokensPerChunk, cudaStream_t stream);
+
+    //! @brief Append one prefill chunk to the active session.
+    //! @details Encodes the mel chunk (when provided) into per-chunk audio embeddings, then runs
+    //!          an append-only prefill that packs ONLY this chunk's token slice onto the committed
+    //!          KV cache. MUST NOT re-run setUpForPrefillExecution. When isFinalChunk is true a
+    //!          token is sampled/emitted and the session transitions to kFinished.
+    //! @param chunkTokenIds Token IDs for THIS chunk only (audio placeholder + any text tokens).
+    //! @param mel           Optional mel-spectrogram chunk; when set it is encoded and its audio
+    //!                      embeddings are bound for this chunk's embedding lookup.
+    //! @param isFinalChunk  Whether this is the last chunk (sample a token after prefill).
+    //! @param stream        CUDA stream.
+    //! @return True on success, false otherwise.
+    bool appendChunk(std::vector<int32_t> const& chunkTokenIds, AudioChunk const& mel, bool isFinalChunk,
+        cudaStream_t stream);
+
+    //! @brief Append a text-only chunk (no audio).
+    bool appendChunk(std::vector<int32_t> const& chunkTokenIds, bool isFinalChunk, cudaStream_t stream);
+
+    //! @brief End the session: reset the runtime for new sequences and clear session context.
+    //! @details Phase 3 uses the full-batch reset (single session/lane). See TODO(phase4).
+    //! @param stream CUDA stream.
+    void endAsrSession(cudaStream_t stream);
+
+    // ── Introspection (spec work-list #5/#6) ─────────────────────────────────
+
+    //! @brief Current session lifecycle status.
+    AsrSessionStatus status() const noexcept
+    {
+        return mStatus;
+    }
+
+    //! @brief Committed KV-cache length for this session's lane (host-side, synchronous).
+    int32_t peekKvCacheLength(cudaStream_t stream)
+    {
+        return mRuntime.peekKvCacheLength(mLane, stream);
+    }
+
+    //! @brief Cumulative number of prefill tokens appended so far (audio+text).
+    int32_t appendedTokens() const noexcept
+    {
+        return mAppendedTokens;
+    }
+
+    //! @brief Number of chunks appended so far.
+    int32_t chunkCount() const noexcept
+    {
+        return mChunkCount;
+    }
+
+    //! @brief Last-step logits for this session's lane (testing/parity surface, spec work-list #6).
+    std::vector<float> getLogitsForTesting(cudaStream_t stream)
+    {
+        return mRuntime.getLogitsForTesting(mLane, stream);
+    }
+
+private:
+    LLMInferenceRuntime& mRuntime;
+    int32_t mLane{0};
+    int32_t mMaxPositions{0};
+    int32_t mAppendedTokens{0};
+    int32_t mChunkCount{0};
+    AsrSessionStatus mStatus{AsrSessionStatus::kIdle};
+
+    DecodingInferenceContext mContext; //!< Session-scoped inference context.
+    rt::Tensor mChunkAudioEmbedding;   //!< Reusable FP16 buffer for per-chunk encoded audio.
+
+    bool appendChunkImpl(std::vector<int32_t> const& chunkTokenIds, rt::audioUtils::AudioData const* mel,
+        bool isFinalChunk, cudaStream_t stream);
+};
+
+} // namespace rt
+} // namespace trt_edgellm
