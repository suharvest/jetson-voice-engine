+// ─────────────────────────────────────────────────────────────────────────────
+// Streaming-ASR session hooks (spec §5 / §2). Narrow primitives composed by
+// AsrStreamingSessionRuntime into a begin/append/end lifecycle.
+// ─────────────────────────────────────────────────────────────────────────────
+
+bool LLMInferenceRuntime::encodeAudioChunk(
+    rt::audioUtils::AudioData const& mel, rt::Tensor& outEmbedding, cudaStream_t stream)
+{
+    // encodeMelChunk lives on the concrete Qwen3-Omni audio runner (Phase 2 patch v080-0001),
+    // not the polymorphic MultimodalRunner base, so resolve it via dynamic_cast.
+    auto* audio = dynamic_cast<Qwen3OmniAudioRunner*>(mAudioRunner.get());
+    if (audio == nullptr)
+    {
+        LOG_ERROR("encodeAudioChunk: no Qwen3OmniAudioRunner available (audio streaming unsupported on this model)");
+        return false;
+    }
+    return audio->encodeMelChunk(mel, outEmbedding, stream);
+}
+
+bool LLMInferenceRuntime::initAsrSessionMRopeLane(int32_t lane, int32_t maxPositions, cudaStream_t stream)
+{
+    if (mAudioRunner == nullptr)
+    {
+        // No audio runner → nothing to initialize (text-only ASR is a no-op here).
+        return true;
+    }
+    // Dispatch polymorphically — base MultimodalRunner provides a no-op default; the Qwen3-Omni
+    // audio runner overrides it to fill one lane row of the shared PipelineIO::mropeCosSin
+    // WITHOUT reshaping the shared buffer (Phase 2 patch v080-0001).
+    return mAudioRunner->initializeSequentialMRopeLane(lane, maxPositions, mPipelineIO->mropeCosSin, stream);
+}
+
+bool LLMInferenceRuntime::setUpAsrSessionPrefill(DecodingInferenceContext& context)
+{
+    // Reuse the exact one-shot setup (LoRA / sys-prompt KV reuse / recurrent-zero / cache-length
+    // reset). Must run ONLY at session begin — chunk appends must never re-enter this (it clears
+    // tokenIds + resets the KV cache). ASR thinker engines are not speculative, so the registry's
+    // priming strategy resolves to the vanilla default decoder (needsStrategyKVCache=false in
+    // setUpForPrefillExecution); no draft cache is touched.
+    DecodingStrategy& strategy = mDecoderRegistry->cachePrimingStrategy();
+    return setUpForPrefillExecution(context, strategy);
+}
+
+bool LLMInferenceRuntime::appendPrefillChunk(DecodingInferenceContext& context,
+    std::vector<rt::SpanI32> const& chunkTokenIds, rt::OptionalInputTensor audioEmbeds, bool sampleAfterPrefill)
+{
+    // Append-only prefill: pack ONLY this chunk's slice onto the committed KV cache. Deliberately
+    // does NOT call setUpForPrefillExecution — that would clear tokenIds + reset the KV cache and
+    // destroy cross-chunk accumulation.
+    return runBaseModelPrefillChunk(context, chunkTokenIds, audioEmbeds, sampleAfterPrefill);
+}
+
+int32_t LLMInferenceRuntime::peekKvCacheLength(int32_t lane, cudaStream_t stream)
+{
+    auto& cacheMgr = *mSharedResources->cacheManagers[0];
+    rt::Tensor& kvLengths = cacheMgr.getKVCacheLengths(); // device INT32 [activeBatchSize]
+    int32_t const activeBatch = cacheMgr.getActiveBatchSize();
+    if (lane < 0 || lane >= activeBatch)
+    {
+        LOG_ERROR("peekKvCacheLength: lane=%d out of range [0, %d)", lane, activeBatch);
+        return -1;
+    }
+    int32_t hostLen = -1;
+    CUDA_CHECK(cudaMemcpyAsync(&hostLen, kvLengths.dataPointer<int32_t>() + lane, sizeof(int32_t),
+        cudaMemcpyDeviceToHost, stream));
+    CUDA_CHECK(cudaStreamSynchronize(stream));
+    return hostLen;
+}
+
+void LLMInferenceRuntime::resetForSessionEnd(cudaStream_t stream)
+{
+    // Phase 3: single session/lane → reuse the existing full-batch reset.
+    // TODO(phase4): per-lane reset via HybridCacheManager::resetLanes so an ASR session can be
+    //               torn down without disturbing co-resident lanes (spec R1).
+    auto& cacheMgr = *mSharedResources->cacheManagers[0];
+    int32_t const activeBatch = cacheMgr.getActiveBatchSize();
+    check::check(mHostReuseKVCacheLengths.reshape({activeBatch}), "Tensor reshape failed");
+    int32_t* reuse = mHostReuseKVCacheLengths.dataPointer<int32_t>();
+    std::fill(reuse, reuse + activeBatch, 0);
+    cacheMgr.resetForNewSequences(mHostReuseKVCacheLengths, stream);
+    CUDA_CHECK(cudaStreamSynchronize(stream));
+}
+
+std::vector<float> LLMInferenceRuntime::getLogitsForTesting(int32_t lane, cudaStream_t stream)
+{
+    auto const& logits = mPipelineIO->outputLogits; // device FP32 [activeBatchSize, outputVocabSize]
+    auto const shape = logits.getShape();
+    if (shape.getNumDims() != 2)
+    {
+        LOG_ERROR("getLogitsForTesting: outputLogits has unexpected rank %d (want 2)", shape.getNumDims());
+        return {};
+    }
+    int32_t const batch = static_cast<int32_t>(shape[0]);
+    int32_t const vocab = static_cast<int32_t>(shape[1]);
+    if (lane < 0 || lane >= batch)
+    {
+        LOG_ERROR("getLogitsForTesting: lane=%d out of range [0, %d)", lane, batch);
+        return {};
+    }
+    std::vector<float> host(static_cast<size_t>(vocab));
+    CUDA_CHECK(cudaMemcpyAsync(host.data(), logits.dataPointer<float>() + static_cast<size_t>(lane) * vocab,
+        static_cast<size_t>(vocab) * sizeof(float), cudaMemcpyDeviceToHost, stream));
+    CUDA_CHECK(cudaStreamSynchronize(stream));
+    return host;
+}
+
+bool LLMInferenceRuntime::allocateChunkAudioEmbedding(rt::Tensor& out, int32_t maxAudioTokens)
+{
+    auto* audio = dynamic_cast<Qwen3OmniAudioRunner*>(mAudioRunner.get());
+    if (audio == nullptr)
+    {
+        LOG_ERROR("allocateChunkAudioEmbedding: no Qwen3OmniAudioRunner available");
+        return false;
+    }
+    int32_t const featureDim = audio->getAudioFeatureDim();
+    if (maxAudioTokens <= 0 || featureDim <= 0)
+    {
+        LOG_ERROR("allocateChunkAudioEmbedding: invalid sizing maxAudioTokens=%d featureDim=%d", maxAudioTokens,
+            featureDim);
+        return false;
+    }
+    // Allocate at full capacity once; encodeMelChunk reshapes within this capacity per chunk.
+    out = rt::Tensor({maxAudioTokens, featureDim}, rt::DeviceType::kGPU, nvinfer1::DataType::kHALF,
+        "asrChunkAudioEmbedding");
+    return true;
+}
