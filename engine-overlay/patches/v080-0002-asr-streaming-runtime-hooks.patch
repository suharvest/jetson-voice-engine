+//! @brief Lightweight non-owning view of a contiguous run of token IDs.
+//! @details C++17 stand-in for std::span<int32_t const> (project is -std=c++17). Used by the
+//!          chunk-prefill helper so a chunk can be packed without copying it into a vector first.
+//!          The viewed storage must outlive the span (callers pass into the same prefill call).
+struct SpanI32
+{
+    int32_t const* ptr{nullptr};
+    std::size_t len{0};
+
+    SpanI32() = default;
+    SpanI32(int32_t const* p, std::size_t n) noexcept
+        : ptr(p)
+        , len(n)
+    {
+    }
+
+    int32_t const* begin() const noexcept
+    {
+        return ptr;
+    }
+    int32_t const* end() const noexcept
+    {
+        return ptr + len;
+    }
+    std::size_t size() const noexcept
+    {
+        return len;
+    }
+    bool empty() const noexcept
+    {
+        return len == 0;
+    }
+};
